# Normalize line endings: LF in the repository, native in the working tree.
* text=auto eol=lf

# Windows-only scripts must keep CRLF to run correctly.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary

# Generated files: collapse diffs in review.
pnpm-lock.yaml linguist-generated=true -diff

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Only the build pins rootDir: it must emit dist/main.js, not dist/src/main.js.
    // The typecheck config omits it so that test/ can be included.
    "rootDir": "./src"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test", "**/*.spec.ts", "**/*.e2e-spec.ts"]
}

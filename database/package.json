{
  "name": "@mobileshop/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, migrations, seeds and database utilities. All database work lives here.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "migrate:reset": "prisma migrate reset --force",
    "reset": "prisma migrate reset --force",
    "seed": "tsx seeds/index.ts",
    "studio": "prisma studio",
    "format": "prisma format",
    "validate": "prisma validate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@mobileshop/shared": "workspace:*",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "dotenv": "17.2.4",
    "prisma": "7.8.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}

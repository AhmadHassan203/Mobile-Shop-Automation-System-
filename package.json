{
  "name": "mobile-shop-automation",
  "version": "0.1.0",
  "private": true,
  "description": "MobileShop OS — production point-of-sale, inventory, purchasing, demand and business-intelligence system for a Lahore mobile shop.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build:dependencies": "pnpm -r --filter ./shared --filter ./database build",
    "build": "pnpm -r --filter ./shared --filter ./database --filter ./backend --filter ./frontend --filter ./e2e build",
    "predev": "pnpm run build:dependencies",
    "dev": "pnpm --parallel --filter ./backend --filter ./frontend dev",
    "lint": "pnpm -r --filter ./shared --filter ./backend --filter ./frontend --filter ./e2e lint",
    "format:check": "prettier --check \"{shared,backend,frontend,database,e2e}/**/*.{ts,tsx,js,json,md}\"",
    "format": "prettier --write \"{shared,backend,frontend,database,e2e}/**/*.{ts,tsx,js,json,md}\"",
    "pretypecheck": "pnpm run build:dependencies",
    "typecheck": "pnpm -r --filter ./shared --filter ./database --filter ./backend --filter ./frontend --filter ./e2e typecheck",
    "pretest": "pnpm run build:dependencies",
    "test": "pnpm -r --filter ./shared --filter ./backend --filter ./frontend test",
    "pretest:unit": "pnpm run build:dependencies",
    "test:unit": "pnpm -r --filter ./shared --filter ./backend --filter ./frontend test:unit",
    "pretest:integration": "pnpm run build:dependencies",
    "test:integration": "pnpm -r --filter ./database --filter ./backend test:integration",
    "test:e2e": "pnpm --filter ./e2e test",
    "db:generate": "pnpm --filter ./database generate",
    "db:migrate": "pnpm --filter ./database migrate",
    "db:migrate:deploy": "pnpm --filter ./database migrate:deploy",
    "db:reset": "pnpm --filter ./database reset",
    "db:seed": "pnpm --filter ./database seed",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:integration && pnpm run build"
  },
  "devDependencies": {
    "prettier": "3.9.5",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "argon2",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  }
}

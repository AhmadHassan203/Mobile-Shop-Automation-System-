// =============================================================================
// MobileShop OS — Prisma schema
// =============================================================================
// All database work lives in database/ (13_ §19).
//
// Conventions applied throughout:
//   * Money is ALWAYS an integer number of minor units (paisa), named *_minor.
//     Never Float, never Decimal-for-money. (05_RULES.md §7, 13_ §23.11)
//   * Timestamps are stored UTC (@db.Timestamptz); Asia/Karachi is a display and
//     business-day concern handled in shared/src/datetime.ts. (05_RULES.md §9)
//   * organization_id / branch_id / location_id exist from day one even though
//     launch is single-branch, so multi-branch needs no data migration. (13_ §8)
//   * Constraints are enforced in the DATABASE, not only in the API. (13_ §4)
//   * Posted records are immutable; corrections use controlled workflows. (13_ §23.9)
//
// Slice 1 defines access, audit and system tables. Later slices add catalog,
// inventory, purchasing, sales, external services, cash and finance.
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

// Prisma 7 removed `url` from the datasource block. The connection string for
// Migrate now lives in prisma.config.ts, and the runtime client receives a
// driver adapter (@prisma/adapter-pg) instead. See database/README.md.
datasource db {
  provider = "postgresql"
}

// =============================================================================
// Organization, branch and stock location
// =============================================================================

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  /// ISO-4217. Stored even though PKR is the only launch currency
  /// (03_ARCHITECTURE.md §8).
  currency  String   @default("PKR") @db.Char(3)
  timezone  String   @default("Asia/Karachi") @db.VarChar(64)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  branches        Branch[]
  users           User[]
  roles           Role[]
  auditEvents     AuditEvent[]
  settings        ApplicationSetting[]
  numberSequences NumberSequence[]
  categories      Category[]
  brands          Brand[]
  productModels   ProductModel[]
  productVariants ProductVariant[]
  productAliases  ProductAlias[]
  productBarcodes ProductBarcode[]

  serializedUnits    SerializedUnit[]
  deviceIdentifiers  DeviceIdentifier[]
  stockBatches       StockBatch[]
  inventoryMovements InventoryMovement[]

  suppliers               Supplier[]
  supplierContacts        SupplierContact[]
  purchaseOrders          PurchaseOrder[]
  purchaseOrderLines      PurchaseOrderLine[]
  goodsReceipts           GoodsReceipt[]
  goodsReceiptLines       GoodsReceiptLine[]
  goodsReceiptLandedCosts GoodsReceiptLandedCost[]
  payables                Payable[]

  @@map("organizations")
}

model Branch {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  code           String   @db.VarChar(20)
  name           String   @db.VarChar(200)
  addressLine    String?  @map("address_line") @db.VarChar(300)
  city           String   @default("Lahore") @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  isDefault      Boolean  @default(false) @map("is_default")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  stockLocations  StockLocation[]
  scopeAccess     UserScopeAccess[]
  auditEvents     AuditEvent[]
  sessions        Session[]
  numberSequences NumberSequence[]
  settings        ApplicationSetting[]

  serializedUnits    SerializedUnit[]
  stockBatches       StockBatch[]
  inventoryMovements InventoryMovement[]

  purchaseOrders          PurchaseOrder[]
  goodsReceipts           GoodsReceipt[]
  goodsReceiptLines       GoodsReceiptLine[]
  goodsReceiptLandedCosts GoodsReceiptLandedCost[]
  payables                Payable[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@index([organizationId, isActive])
  @@map("branches")
}

model StockLocation {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  branchId       String            @map("branch_id") @db.Uuid
  code           String            @db.VarChar(20)
  name           String            @db.VarChar(200)
  /// The public inventory contract calls this `locationType`; the column keeps
  /// the name migration 0001 applied.
  kind           StockLocationKind @default(store)
  /// Exactly one location per branch is the default receiving/selling location.
  isDefault      Boolean           @default(false) @map("is_default")
  isActive       Boolean           @default(true) @map("is_active")
  /// Optimistic concurrency token, added by 0007 so two managers editing one
  /// location cannot silently overwrite each other. A CHECK (> 0) guards it in
  /// SQL and is not expressible here.
  version        Int               @default(1)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  branch      Branch            @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  scopeAccess UserScopeAccess[]

  serializedUnits SerializedUnit[]
  stockBatches    StockBatch[]
  movements       InventoryMovement[]
  receiptLines    GoodsReceiptLine[]

  @@unique([organizationId, branchId, code])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, isActive])
  @@map("stock_locations")
}

/// Physical and virtual stock locations (01_PRD.md §5.4).
enum StockLocationKind {
  store
  warehouse
  /// Non-physical holding areas: quarantine, repair bench, in-transit.
  virtual
}

// =============================================================================
// Catalog
// =============================================================================

/// Category/subcategory tree. Products remain inactive rather than being
/// deleted once historical transactions reference them (05_RULES.md §2).
model Category {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  parentCategoryId String?  @map("parent_category_id") @db.Uuid
  name             String   @db.VarChar(200)
  slug             String   @db.VarChar(220)
  isActive         Boolean  @default(true) @map("is_active")
  /// Optimistic concurrency token. A self-parent check and a cycle-rejecting
  /// trigger guard the tree in SQL (0006); neither is expressible here.
  version          Int      @default(1)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parent        Category?      @relation("CategoryTree", fields: [parentCategoryId, organizationId], references: [id, organizationId], onDelete: Restrict)
  children      Category[]     @relation("CategoryTree")
  productModels ProductModel[]

  @@unique([organizationId, slug])
  @@unique([id, organizationId])
  @@index([organizationId, parentCategoryId, isActive])
  @@map("categories")
}

model Brand {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(200)
  slug           String   @db.VarChar(220)
  isActive       Boolean  @default(true) @map("is_active")
  /// Optimistic concurrency token (0006).
  version        Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  productModels ProductModel[]

  @@unique([organizationId, slug])
  @@unique([id, organizationId])
  @@index([organizationId, isActive, name])
  @@map("brands")
}

model ProductModel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  brandId        String   @map("brand_id") @db.Uuid
  categoryId     String   @map("category_id") @db.Uuid
  name           String   @db.VarChar(200)
  canonicalName  String   @map("canonical_name") @db.VarChar(200)
  isActive       Boolean  @default(true) @map("is_active")
  /// Optimistic concurrency token (0006).
  version        Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  brand        Brand            @relation(fields: [brandId, organizationId], references: [id, organizationId], onDelete: Restrict)
  category     Category         @relation(fields: [categoryId, organizationId], references: [id, organizationId], onDelete: Restrict)
  variants     ProductVariant[]

  @@unique([organizationId, brandId, canonicalName])
  @@unique([id, organizationId])
  @@index([organizationId, categoryId, isActive])
  @@index([organizationId, brandId, isActive])
  @@map("product_models")
}

/// Sellable definition. A serialized physical phone is a later
/// SerializedInventoryUnit, never a ProductVariant (04_DATA_MODEL.md §3).
model ProductVariant {
  id                String           @id @default(uuid()) @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  productModelId    String           @map("product_model_id") @db.Uuid
  sku               String           @db.VarChar(100)
  name              String           @db.VarChar(240)
  trackingType      TrackingType     @map("tracking_type")
  condition         ProductCondition
  ptaStatus         PtaStatus        @map("pta_status")
  ram               String?          @db.VarChar(100)
  storage           String?          @db.VarChar(100)
  color             String?          @db.VarChar(100)
  region            String?          @db.VarChar(100)
  warrantyType      WarrantyType     @default(none) @map("warranty_type")
  warrantyMonths    Int?             @map("warranty_months")
  attributes        Json?
  /// Reserved for the pricing slice. Catalog create cannot set these values.
  defaultPriceMinor BigInt?          @map("default_price_minor")
  minPriceMinor     BigInt?          @map("min_price_minor")
  reorderPoint      Int?             @map("reorder_point")
  casePackSize      Int?             @map("case_pack_size")
  isActive          Boolean          @default(true) @map("is_active")
  version           Int              @default(1)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  productModel ProductModel     @relation(fields: [productModelId, organizationId], references: [id, organizationId], onDelete: Restrict)
  aliases      ProductAlias[]
  barcodes     ProductBarcode[]

  serializedUnits    SerializedUnit[]
  stockBatches       StockBatch[]
  movements          InventoryMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines  GoodsReceiptLine[]

  @@unique([organizationId, sku])
  @@unique([id, organizationId])
  /// Supports the receipt-line FK that proves the caller's tracking type is
  /// the variant's stored tracking type rather than an untrusted body value.
  @@unique([id, organizationId, trackingType])
  @@index([organizationId, productModelId, isActive])
  @@index([organizationId, name])
  @@map("product_variants")
}

model ProductAlias {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  alias            String   @db.VarChar(200)
  normalizedAlias  String   @map("normalized_alias") @db.VarChar(200)
  source           String?  @db.VarChar(40)
  /// Aliases are retired, never deleted (the 0005 hard-delete trigger still
  /// applies). Uniqueness of `normalized_alias` is therefore a partial unique
  /// index `WHERE is_active` (0006) so a retired alias frees its value. Prisma
  /// cannot express a partial index, so it is intentionally absent below and
  /// enforced only in SQL.
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  productVariant ProductVariant @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, productVariantId])
  @@map("product_aliases")
}

model ProductBarcode {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  barcode          String   @db.VarChar(128)
  /// Vocabulary is intentionally deferred; the first public contract accepts
  /// the barcode value only and does not invent a barcode taxonomy.
  barcodeType      String?  @map("barcode_type") @db.VarChar(30)
  isPrimary        Boolean  @default(false) @map("is_primary")
  /// Barcodes are retired, never deleted. As with aliases, uniqueness of
  /// `barcode` is a partial unique index `WHERE is_active` (0006) and so cannot
  /// be declared here. SQL additionally checks that a retired barcode is never
  /// left flagged primary.
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  productVariant ProductVariant @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, productVariantId])
  @@map("product_barcodes")
}

// =============================================================================
// Inventory
// =============================================================================
// Balances are DERIVED from inventory_movements plus the unit and batch rows.
// There is deliberately no stored balance table: a cached total is one bug away
// from disagreeing with the ledger that produced it (04_DATA_MODEL.md §5).

/// One physical serialized device. A ProductVariant is the sellable definition;
/// this is the handset on the shelf (04_DATA_MODEL.md §3).
model SerializedUnit {
  id                  String               @id @default(uuid()) @db.Uuid
  organizationId      String               @map("organization_id") @db.Uuid
  branchId            String               @map("branch_id") @db.Uuid
  productVariantId    String               @map("product_variant_id") @db.Uuid
  stockLocationId     String               @map("stock_location_id") @db.Uuid
  /// Purchasing provenance is nullable only for pre-0008 stock and controlled
  /// non-purchase acquisition workflows. SQL requires both values together and
  /// the receipt-line composite FK proves immutable source/variant consistency.
  /// Current branch/location deliberately stay outside that FK so movements can
  /// relocate a received handset without rewriting its receipt provenance.
  purchaseOrderLineId String?              @map("purchase_order_line_id") @db.Uuid
  goodsReceiptLineId  String?              @map("goods_receipt_line_id") @db.Uuid
  state               SerializedStockState
  condition           ProductCondition
  ptaStatus           PtaStatus            @map("pta_status")
  receivedAt          DateTime?            @map("received_at") @db.Timestamptz(3)
  /// Reserved for the purchasing slice, which owns cost. The inventory API
  /// neither accepts nor exposes these values: no inventory request can set
  /// them and no inventory response carries them (shared/src/inventory.ts).
  /// SQL requires financially posted receipt units to have both values plus
  /// receivedAt, and any landed value must be at least the actual value.
  actualCostMinor     BigInt?              @map("actual_cost_minor")
  landedCostMinor     BigInt?              @map("landed_cost_minor")
  /// Optimistic concurrency token; CHECK (> 0) lives in SQL (0007).
  version             Int                  @default(1)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch            Branch             @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  productVariant    ProductVariant     @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId, organizationId, productVariantId], references: [id, organizationId, productVariantId], onDelete: Restrict)
  goodsReceiptLine  GoodsReceiptLine?  @relation(fields: [goodsReceiptLineId, organizationId, productVariantId, purchaseOrderLineId], references: [id, organizationId, productVariantId, purchaseOrderLineId], onDelete: Restrict)
  /// Keyed on (id, organization_id, branch_id) rather than (id, organization_id):
  /// this is what forces a unit's branch to agree with its location's branch.
  stockLocation     StockLocation      @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)

  identifiers DeviceIdentifier[]
  movements   InventoryMovement[]

  @@unique([id, organizationId])
  @@index([organizationId, productVariantId, state])
  @@index([organizationId, stockLocationId, state])
  @@index([organizationId, receivedAt])
  @@map("serialized_units")
}

/// The IMEI-uniqueness backbone.
///
/// A separate table rather than imei1/imei2/serial columns on the unit, so that
/// every identifier shares ONE uniqueness namespace per organization: the same
/// IMEI cannot be imei1 on one handset and imei2 on another (05_RULES.md §1.1).
model DeviceIdentifier {
  id               String               @id @default(uuid()) @db.Uuid
  organizationId   String               @map("organization_id") @db.Uuid
  serializedUnitId String               @map("serialized_unit_id") @db.Uuid
  identifierType   DeviceIdentifierType @map("identifier_type")
  /// Stable slot identity: IMEI 1/2 and serial 1. SQL backfills legacy rows,
  /// constrains the valid type/position combinations and freezes identifiers
  /// once their serialized unit is linked to a posted goods receipt (0009).
  position         Int                  @db.SmallInt
  /// Normalized form (shared/src/imei.ts normalizeImei/normalizeSerial), so
  /// "356938-035643809" and "356938035643809" collide instead of both entering
  /// stock. A CHECK constrains it to the normalized alphabet.
  normalizedValue  String               @map("normalized_value") @db.VarChar(64)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  serializedUnit SerializedUnit @relation(fields: [serializedUnitId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, normalizedValue])
  @@unique([serializedUnitId, identifierType, position], map: "device_identifiers_unit_type_position_key")
  @@index([organizationId, serializedUnitId])
  @@map("device_identifiers")
}

/// Quantity-tracked stock: one row per variant per location.
model StockBatch {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  branchId         String    @map("branch_id") @db.Uuid
  productVariantId String    @map("product_variant_id") @db.Uuid
  stockLocationId  String    @map("stock_location_id") @db.Uuid
  /// CHECK (>= 0) in SQL: 13_ §23 blocks negative stock at the database, not
  /// merely in the API.
  quantityOnHand   Int       @default(0) @map("quantity_on_hand")
  /// CHECK (>= 0 AND <= quantity_on_hand) in SQL.
  quantityReserved Int       @default(0) @map("quantity_reserved")
  /// Current moving weighted-average unit costs (ASM-005), not historical
  /// receipt evidence. Exact received costs remain on immutable receipt lines.
  /// Both NULL means explicitly uncosted; otherwise both must be present and
  /// landed cost must be at least actual cost.
  actualCostMinor  BigInt?   @map("actual_cost_minor")
  landedCostMinor  BigInt?   @map("landed_cost_minor")
  receivedAt       DateTime? @map("received_at") @db.Timestamptz(3)
  /// Optimistic concurrency token; CHECK (> 0) lives in SQL (0007).
  version          Int       @default(1)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch         Branch         @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  productVariant ProductVariant @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  stockLocation  StockLocation  @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)

  movements    InventoryMovement[]
  receiptLines GoodsReceiptLine[]

  @@unique([organizationId, productVariantId, stockLocationId])
  @@unique([id, organizationId])
  /// Receipt lines use this key so a named aggregate bucket cannot belong to a
  /// different branch, variant or location than the stock it receives.
  @@unique([id, organizationId, branchId, productVariantId, stockLocationId])
  @@map("stock_batches")
}

/// The append-only inventory ledger (04_DATA_MODEL.md §5).
///
/// Never updated or deleted: a correction is a new compensating movement. A
/// BEFORE UPDATE OR DELETE OR TRUNCATE trigger and an explicit REVOKE enforce
/// that at the database, not merely by convention (0007).
///
/// Direction is carried by `movement_type` through MOVEMENT_ON_HAND_SIGN, never
/// by a negative quantity — CHECK (quantity > 0) makes that unrepresentable.
model InventoryMovement {
  id               String                @id @default(uuid()) @db.Uuid
  organizationId   String                @map("organization_id") @db.Uuid
  branchId         String                @map("branch_id") @db.Uuid
  productVariantId String                @map("product_variant_id") @db.Uuid
  /// Exactly one of serialized_unit_id / stock_batch_id is set; a CHECK with
  /// `<>` over the two NULL tests enforces the exclusivity in SQL.
  serializedUnitId String?               @map("serialized_unit_id") @db.Uuid
  stockBatchId     String?               @map("stock_batch_id") @db.Uuid
  stockLocationId  String                @map("stock_location_id") @db.Uuid
  movementType     MovementType          @map("movement_type")
  quantity         Int
  /// Set only for serialized movements; a CHECK keeps them NULL otherwise.
  fromState        SerializedStockState? @map("from_state")
  toState          SerializedStockState? @map("to_state")
  referenceType    String?               @map("reference_type") @db.VarChar(40)
  referenceId      String?               @map("reference_id") @db.Uuid
  reason           String?               @db.VarChar(500)
  actorUserId      String                @map("actor_user_id") @db.Uuid
  occurredAt       DateTime              @default(now()) @map("occurred_at") @db.Timestamptz(3)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch         Branch          @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  productVariant ProductVariant  @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  serializedUnit SerializedUnit? @relation(fields: [serializedUnitId, organizationId], references: [id, organizationId], onDelete: Restrict)
  stockBatch     StockBatch?     @relation(fields: [stockBatchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  stockLocation  StockLocation   @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  actor          User            @relation("InventoryMovementActor", fields: [actorUserId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, productVariantId, occurredAt])
  @@index([organizationId, serializedUnitId, occurredAt])
  @@index([organizationId, movementType, occurredAt])
  @@index([referenceType, referenceId])
  @@map("inventory_movements")
}

/// Serialized device lifecycle (05_RULES.md §3). Order and values mirror
/// shared/src/enums.ts SERIALIZED_STOCK_STATES exactly; allowed transitions are
/// decided by isTransitionAllowed() in the domain service.
enum SerializedStockState {
  pending_verification
  quarantined
  available
  reserved
  sold
  returned_inspection
  defective
  supplier_warranty
  customer_warranty
  repair
  written_off
  purchase_returned
}

/// Mirrors shared/src/enums.ts MOVEMENT_TYPES exactly (04_DATA_MODEL.md §5).
enum MovementType {
  purchase_receive
  sale
  sale_return
  purchase_return
  transfer_out
  transfer_in
  reserve
  release
  adjustment_in
  adjustment_out
  damage
  write_off
  repair_issue
  repair_return
}

/// IMEI and serial share one uniqueness namespace, so the kind is a column
/// rather than a separate table (shared/src/inventory.ts DEVICE_IDENTIFIER_TYPES).
enum DeviceIdentifierType {
  imei
  serial
}

enum TrackingType {
  serialized
  quantity
}

enum ProductCondition {
  new
  used
  open_box
  refurbished
}

enum PtaStatus {
  pta_approved
  non_pta
  pta_pending
  not_applicable
  unknown
}

enum WarrantyType {
  official
  local
  shop
  none
  supplier
}

// =============================================================================
// Suppliers, purchasing, receiving and payable creation
// =============================================================================

/// Organization-level supplier master. Suppliers are deactivated, never
/// deleted, because posted purchase records retain their identity forever.
model Supplier {
  id                    String   @id @default(uuid()) @db.Uuid
  organizationId        String   @map("organization_id") @db.Uuid
  /// Normalized by shared/src/purchasing.ts before write. SQL pins the same
  /// alphabet and a tenant-scoped unique index is the final duplicate guard.
  code                  String   @db.VarChar(40)
  name                  String   @db.VarChar(200)
  paymentTermsDays      Int      @default(0) @map("payment_terms_days")
  leadTimeDays          Int      @default(0) @map("lead_time_days")
  onTimeRateBasisPoints Int?     @map("on_time_rate_basis_points")
  addressLine           String?  @map("address_line") @db.VarChar(300)
  city                  String?  @db.VarChar(100)
  notes                 String?  @db.VarChar(500)
  isActive              Boolean  @default(true) @map("is_active")
  version               Int      @default(1)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  contacts       SupplierContact[]
  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]
  payables       Payable[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@index([organizationId, isActive, name])
  @@map("suppliers")
}

/// Replace-semantics supplier contacts. Old contacts are retired with
/// is_active so historical references and audit snapshots are never orphaned.
model SupplierContact {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  supplierId     String   @map("supplier_id") @db.Uuid
  name           String   @db.VarChar(200)
  role           String?  @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  email          String?  @db.VarChar(255)
  isPrimary      Boolean  @default(false) @map("is_primary")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  supplier     Supplier     @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@index([organizationId, supplierId, isActive])
  /// Exactly one active primary contact is a partial unique index in 0008;
  /// Prisma cannot represent the WHERE predicate.
  @@map("supplier_contacts")
}

/// A purchase order is commercial intent only. It never creates stock; the
/// immutable goods receipt below is the transaction that does (05_RULES §1.5).
model PurchaseOrder {
  id                 String              @id @default(uuid()) @db.Uuid
  organizationId     String              @map("organization_id") @db.Uuid
  branchId           String              @map("branch_id") @db.Uuid
  supplierId         String              @map("supplier_id") @db.Uuid
  createdByUserId    String              @map("created_by_user_id") @db.Uuid
  approvedByUserId   String?             @map("approved_by_user_id") @db.Uuid
  orderedByUserId    String?             @map("ordered_by_user_id") @db.Uuid
  closedByUserId     String?             @map("closed_by_user_id") @db.Uuid
  cancelledByUserId  String?             @map("cancelled_by_user_id") @db.Uuid
  number             String              @db.VarChar(100)
  status             PurchaseOrderStatus @default(draft)
  orderDate          DateTime            @default(dbgenerated("CURRENT_DATE")) @map("order_date") @db.Date
  expectedOn         DateTime?           @map("expected_on") @db.Date
  notes              String?             @db.VarChar(500)
  approvedAt         DateTime?           @map("approved_at") @db.Timestamptz(3)
  orderedAt          DateTime?           @map("ordered_at") @db.Timestamptz(3)
  closedAt           DateTime?           @map("closed_at") @db.Timestamptz(3)
  cancelledAt        DateTime?           @map("cancelled_at") @db.Timestamptz(3)
  cancellationReason String?             @map("cancellation_reason") @db.VarChar(500)
  version            Int                 @default(1)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch              @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  supplier     Supplier            @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdBy    User                @relation("PurchaseOrderCreator", fields: [createdByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  approvedBy   User?               @relation("PurchaseOrderApprover", fields: [approvedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  orderedBy    User?               @relation("PurchaseOrderOrderer", fields: [orderedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  closedBy     User?               @relation("PurchaseOrderCloser", fields: [closedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  cancelledBy  User?               @relation("PurchaseOrderCanceller", fields: [cancelledByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lines        PurchaseOrderLine[]
  receipts     GoodsReceipt[]

  @@unique([organizationId, branchId, number])
  @@unique([id, organizationId])
  @@unique([id, organizationId, branchId, supplierId])
  @@index([organizationId, branchId, status, orderDate])
  @@index([organizationId, supplierId, orderDate])
  @@map("purchase_orders")
}

/// Ordered and received quantities share a row so `received <= ordered` has a
/// database CHECK backstop. Exact ordered cost is never inferred from catalog.
model PurchaseOrderLine {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  purchaseOrderId  String   @map("purchase_order_id") @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  lineNumber       Int      @map("line_number")
  quantityOrdered  Int      @map("quantity_ordered")
  quantityReceived Int      @default(0) @map("quantity_received")
  unitCostMinor    BigInt   @map("unit_cost_minor")
  notes            String?  @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId, organizationId], references: [id, organizationId], onDelete: Restrict)
  productVariant  ProductVariant     @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  receiptLines    GoodsReceiptLine[]
  serializedUnits SerializedUnit[]

  @@unique([organizationId, purchaseOrderId, lineNumber])
  @@unique([organizationId, purchaseOrderId, productVariantId])
  @@unique([id, organizationId])
  @@unique([id, organizationId, productVariantId])
  @@unique([id, organizationId, purchaseOrderId, productVariantId])
  @@index([organizationId, productVariantId])
  @@map("purchase_order_lines")
}

/// Immutable proof that stock actually arrived. All totals are calculated by
/// the server in TXN-1 and rechecked against immutable child rows at COMMIT.
model GoodsReceipt {
  id                         String                     @id @default(uuid()) @db.Uuid
  organizationId             String                     @map("organization_id") @db.Uuid
  branchId                   String                     @map("branch_id") @db.Uuid
  purchaseOrderId            String                     @map("purchase_order_id") @db.Uuid
  supplierId                 String                     @map("supplier_id") @db.Uuid
  receivedByUserId           String                     @map("received_by_user_id") @db.Uuid
  number                     String                     @db.VarChar(100)
  supplierInvoiceReference   String?                    @map("supplier_invoice_reference") @db.VarChar(100)
  receivedAt                 DateTime                   @default(now()) @map("received_at") @db.Timestamptz(3)
  invoiceDueOn               DateTime                   @map("invoice_due_on") @db.Date
  notes                      String?                    @db.VarChar(500)
  landedCostAllocationMethod LandedCostAllocationMethod @default(by_value) @map("landed_cost_allocation_method")
  actualCostTotalMinor       BigInt                     @map("actual_cost_total_minor")
  landedCostTotalMinor       BigInt                     @map("landed_cost_total_minor")
  payableTotalMinor          BigInt                     @map("payable_total_minor")
  /// Optional for legacy receipts. New idempotent posting requests persist the
  /// client key with a lowercase SHA-256 hash of the canonical request (0010).
  idempotencyKey             String?                    @map("idempotency_key") @db.Uuid
  requestHash                String?                    @map("request_hash") @db.Char(64)
  /// Child rows must be inserted in this same transaction; the trigger in
  /// 0008 rejects a later INSERT that would rewrite posted receipt history.
  postingTxid                BigInt                     @default(dbgenerated("txid_current()")) @map("posting_txid")
  createdAt                  DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)

  organization  Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch        Branch                   @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  supplier      Supplier                 @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)
  purchaseOrder PurchaseOrder            @relation(fields: [purchaseOrderId, organizationId, branchId, supplierId], references: [id, organizationId, branchId, supplierId], onDelete: Restrict)
  receivedBy    User                     @relation("GoodsReceiptReceiver", fields: [receivedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lines         GoodsReceiptLine[]
  landedCosts   GoodsReceiptLandedCost[]
  payable       Payable?

  @@unique([organizationId, branchId, number])
  @@unique([organizationId, branchId, idempotencyKey], map: "goods_receipts_idempotency_scope_key")
  @@unique([id, organizationId])
  @@unique([id, organizationId, branchId])
  @@unique([id, organizationId, branchId, purchaseOrderId])
  @@unique([id, organizationId, branchId, supplierId])
  @@index([organizationId, purchaseOrderId, receivedAt])
  @@index([organizationId, supplierId, receivedAt])
  @@map("goods_receipts")
}

/// Immutable exact received-cost evidence. Quantity stock points at the one
/// aggregate bucket it updated; serialized stock points back here from each
/// unit instead. The source FKs prove the receipt, PO line, variant and
/// destination all describe the same tenant-scoped arrival.
model GoodsReceiptLine {
  id                       String       @id @default(uuid()) @db.Uuid
  organizationId           String       @map("organization_id") @db.Uuid
  branchId                 String       @map("branch_id") @db.Uuid
  goodsReceiptId           String       @map("goods_receipt_id") @db.Uuid
  purchaseOrderId          String       @map("purchase_order_id") @db.Uuid
  purchaseOrderLineId      String       @map("purchase_order_line_id") @db.Uuid
  productVariantId         String       @map("product_variant_id") @db.Uuid
  stockLocationId          String       @map("stock_location_id") @db.Uuid
  trackingType             TrackingType @map("tracking_type")
  quantityReceived         Int          @map("quantity_received")
  unitCostMinor            BigInt       @map("unit_cost_minor")
  actualCostTotalMinor     BigInt       @map("actual_cost_total_minor")
  landedCostAllocatedMinor BigInt       @map("landed_cost_allocated_minor")
  landedCostTotalMinor     BigInt       @map("landed_cost_total_minor")
  stockBatchId             String?      @map("stock_batch_id") @db.Uuid
  createdAt                DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch            Branch            @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  goodsReceipt      GoodsReceipt      @relation(fields: [goodsReceiptId, organizationId, branchId, purchaseOrderId], references: [id, organizationId, branchId, purchaseOrderId], onDelete: Restrict)
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId, organizationId, purchaseOrderId, productVariantId], references: [id, organizationId, purchaseOrderId, productVariantId], onDelete: Restrict)
  productVariant    ProductVariant    @relation(fields: [productVariantId, organizationId, trackingType], references: [id, organizationId, trackingType], onDelete: Restrict)
  stockLocation     StockLocation     @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  stockBatch        StockBatch?       @relation(fields: [stockBatchId, organizationId, branchId, productVariantId, stockLocationId], references: [id, organizationId, branchId, productVariantId, stockLocationId], onDelete: Restrict)
  serializedUnits   SerializedUnit[]

  @@unique([organizationId, goodsReceiptId, purchaseOrderLineId, stockLocationId])
  @@unique([id, organizationId])
  /// Immutable source key for serialized provenance. Receiving destination is
  /// evidence on this row, not part of the unit's mutable current-location FK.
  @@unique([id, organizationId, productVariantId, purchaseOrderLineId])
  @@index([organizationId, purchaseOrderLineId])
  @@index([organizationId, productVariantId, createdAt])
  @@map("goods_receipt_lines")
}

/// Freight, customs, insurance and other landed-cost components. Entries are
/// immutable and their sum must equal receipt allocations at transaction end.
model GoodsReceiptLandedCost {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  branchId       String         @map("branch_id") @db.Uuid
  goodsReceiptId String         @map("goods_receipt_id") @db.Uuid
  kind           LandedCostKind
  amountMinor    BigInt         @map("amount_minor")
  reference      String?        @db.VarChar(100)
  notes          String?        @db.VarChar(500)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@index([organizationId, goodsReceiptId])
  @@map("goods_receipt_landed_costs")
}

/// Product-invoice obligation created atomically by receiving. Landed-cost
/// entries increase inventory value but are not owed to the product supplier;
/// settlement extends this row later while its source and amount stay fixed.
model Payable {
  id               String        @id @default(uuid()) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  branchId         String        @map("branch_id") @db.Uuid
  supplierId       String        @map("supplier_id") @db.Uuid
  goodsReceiptId   String        @map("goods_receipt_id") @db.Uuid
  dueOn            DateTime      @map("due_on") @db.Date
  amountMinor      BigInt        @map("amount_minor")
  paidMinor        BigInt        @default(0) @map("paid_minor")
  outstandingMinor BigInt        @map("outstanding_minor")
  status           PayableStatus @default(open)
  version          Int           @default(1)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  supplier     Supplier     @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)
  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId, organizationId, branchId, supplierId], references: [id, organizationId, branchId, supplierId], onDelete: Restrict)

  @@unique([organizationId, goodsReceiptId])
  @@unique([goodsReceiptId, organizationId, branchId, supplierId])
  @@unique([id, organizationId])
  @@index([organizationId, supplierId, status, dueOn])
  @@index([organizationId, status, dueOn])
  @@map("payables")
}

enum PurchaseOrderStatus {
  draft
  approved
  ordered
  partially_received
  received
  closed
  cancelled
}

enum LandedCostKind {
  freight
  customs
  insurance
  handling
  tax
  other
}

enum LandedCostAllocationMethod {
  by_value
}

enum PayableStatus {
  open
  partially_paid
  paid
  cancelled
}

// =============================================================================
// Users, roles and permissions
// =============================================================================

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  /// Normalized to lowercase before write; unique per organization.
  email              String    @db.VarChar(255)
  /// Argon2id hash (ASM-012). NEVER logged, never returned by any endpoint.
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  fullName           String    @map("full_name") @db.VarChar(200)
  /// E.164, e.g. +923001234567 (shared/src/phone.ts).
  phone              String?   @db.VarChar(20)
  /// Deactivation revokes access immediately; users are never hard-deleted
  /// because they are referenced by posted records and audit history.
  isActive           Boolean   @default(true) @map("is_active")
  /// Forces a password change on next login (invited or reset users).
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz(3)
  /// Consecutive failed attempts; reset on success. Feeds lockout.
  failedLoginCount   Int       @default(0) @map("failed_login_count")
  lockedUntil        DateTime? @map("locked_until") @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  userRoles         UserRole[]           @relation("UserRoleMember")
  assignedUserRoles UserRole[]           @relation("UserRoleAssigner")
  scopeAccess       UserScopeAccess[]
  sessions          Session[]
  auditEvents       AuditEvent[]
  updatedSettings   ApplicationSetting[] @relation("SettingUpdater")

  inventoryMovements InventoryMovement[] @relation("InventoryMovementActor")

  createdPurchaseOrders   PurchaseOrder[] @relation("PurchaseOrderCreator")
  approvedPurchaseOrders  PurchaseOrder[] @relation("PurchaseOrderApprover")
  orderedPurchaseOrders   PurchaseOrder[] @relation("PurchaseOrderOrderer")
  closedPurchaseOrders    PurchaseOrder[] @relation("PurchaseOrderCloser")
  cancelledPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCanceller")
  receivedGoodsReceipts   GoodsReceipt[]  @relation("GoodsReceiptReceiver")

  @@unique([organizationId, email])
  @@unique([id, organizationId])
  @@index([organizationId, isActive])
  @@map("users")
}

model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  /// Stable machine code: owner, manager, salesperson, cashier, purchaser,
  /// accountant, technician (shared/src/permissions.ts ROLES).
  code           String   @db.VarChar(50)
  name           String   @db.VarChar(100)
  description    String?  @db.VarChar(500)
  /// System roles are seeded and cannot be deleted; their grants stay editable.
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@map("roles")
}

/// Permission catalogue. Rows mirror shared/src/permissions.ts PERMISSIONS and
/// are reconciled by the seed, so code and database cannot drift apart.
model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  /// resource.action, e.g. "sales.post".
  key         String   @unique @db.VarChar(100)
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?  @db.VarChar(300)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model UserRole {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  roleId         String   @map("role_id") @db.Uuid
  assignedAt     DateTime @default(now()) @map("assigned_at") @db.Timestamptz(3)
  assignedBy     String?  @map("assigned_by_user_id") @db.Uuid

  user     User  @relation("UserRoleMember", fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  role     Role  @relation(fields: [roleId, organizationId], references: [id, organizationId], onDelete: Restrict)
  assigner User? @relation("UserRoleAssigner", fields: [assignedBy, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, userId, roleId])
  @@index([organizationId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at") @db.Timestamptz(3)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// Restricts a user to specific branches/locations (13_ §8, §23.21).
/// A user with NO rows here is scoped to their organization's default branch;
/// resolution lives in the scope guard, never in the client.
model UserScopeAccess {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  /// Null grants the whole branch; non-null narrows the grant to one location.
  locationId     String?  @map("location_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user     User           @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  branch   Branch         @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Cascade)
  location StockLocation? @relation(fields: [locationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Cascade)

  @@unique([organizationId, userId, branchId, locationId])
  @@index([organizationId, userId])
  @@map("user_scope_access")
}

// =============================================================================
// Sessions
// =============================================================================

/// Server-side session (ASM-011).
///
/// Server-side rather than a self-contained JWT so that deactivating a user or
/// revoking a session takes effect immediately — 13_ §8 requires activation/
/// deactivation to be meaningful, which a stateless token cannot guarantee until
/// it expires.
model Session {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  /// SHA-256 of the opaque cookie value. The raw token is never stored, so a
  /// database leak does not hand over live sessions.
  tokenHash      String    @unique @map("token_hash") @db.VarChar(64)
  /// Active branch for this session; the launch UI exposes no branch selector.
  branchId       String    @map("branch_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(3)
  /// Truncated/normalized; retained for the login audit trail (13_ §8).
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  userAgent      String?   @map("user_agent") @db.VarChar(400)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  lastSeenAt     DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(3)

  user   User   @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  branch Branch @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Login attempt log, separate from AuditEvent because it is written on failure
/// for users that may not exist, and drives rate limiting/lockout (13_ §8).
model LoginAttempt {
  id            String   @id @default(uuid()) @db.Uuid
  /// Raw submitted identifier, lowercased. Not an FK: failures include unknown users.
  email         String   @db.VarChar(255)
  succeeded     Boolean
  failureReason String?  @map("failure_reason") @db.VarChar(100)
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(400)
  requestId     String?  @map("request_id") @db.VarChar(128)
  attemptedAt   DateTime @default(now()) @map("attempted_at") @db.Timestamptz(3)

  @@index([email, attemptedAt])
  @@index([ipAddress, attemptedAt])
  @@map("login_attempts")
}

// =============================================================================
// Audit
// =============================================================================

/// Append-only audit log (04_DATA_MODEL.md §10, 03_ARCHITECTURE.md §9).
///
/// Never updated or deleted by application code. Payloads hold safe snapshots
/// only — never secrets, tokens, or full sensitive documents (04_DATA_MODEL §10).
model AuditEvent {
  id             String           @id @default(uuid()) @db.Uuid
  occurredAt     DateTime         @default(now()) @map("occurred_at") @db.Timestamptz(3)
  organizationId String           @map("organization_id") @db.Uuid
  branchId       String?          @map("branch_id") @db.Uuid
  /// Null for system/unauthenticated actions (e.g. a failed login).
  actorUserId    String?          @map("actor_user_id") @db.Uuid
  /// Dotted action, e.g. "sale.posted", "inventory.adjusted".
  action         String           @db.VarChar(100)
  entityType     String           @map("entity_type") @db.VarChar(60)
  entityId       String?          @map("entity_id") @db.VarChar(64)
  /// Safe before/after snapshots. Redacted at the writer, not here.
  beforeSnapshot Json?            @map("before_snapshot")
  afterSnapshot  Json?            @map("after_snapshot")
  beforeHash     String?          @map("before_hash") @db.Char(64)
  afterHash      String?          @map("after_hash") @db.Char(64)
  /// Mandatory for overrides and sensitive actions (13_ §23.22).
  reason         String?          @db.VarChar(500)
  requestId      String?          @map("request_id") @db.VarChar(128)
  ipAddress      String?          @map("ip_address") @db.VarChar(45)
  userAgent      String?          @map("user_agent") @db.VarChar(400)
  sensitivity    AuditSensitivity @default(normal)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch?      @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  actor        User?        @relation(fields: [actorUserId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, occurredAt])
  @@index([entityType, entityId])
  @@index([actorUserId, occurredAt])
  @@index([action, occurredAt])
  @@map("audit_events")
}

enum AuditSensitivity {
  normal
  /// Restricted entries (identity documents, exports of personal data) are
  /// visible only to users holding audit.view (04_DATA_MODEL.md §10).
  restricted
}

// =============================================================================
// System
// =============================================================================

/// Runtime configuration the owner can change without a deploy
/// (05_RULES.md §9: "no hidden magic numbers; configuration is named and versioned").
model ApplicationSetting {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  /// Null means organization default; a branch row overrides that default.
  branchId       String?          @map("branch_id") @db.Uuid
  /// Dotted key, e.g. "sales.min_margin_percent".
  key            String           @db.VarChar(120)
  value          Json
  valueType      SettingValueType @default(json) @map("value_type")
  description    String?          @db.VarChar(300)
  /// Optimistic concurrency for concurrent settings edits.
  version        Int              @default(1)
  updatedBy      String?          @map("updated_by") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  updater      User?        @relation("SettingUpdater", fields: [updatedBy, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, branchId, key])
  @@map("application_settings")
}

enum SettingValueType {
  boolean
  integer
  money_minor
  string
  json
}

/// Gapless human-facing document numbers (ASM-018).
///
/// Allocated inside the posting transaction under a row lock, so numbering has
/// no gaps — which is what an auditor expects. At this shop's volume the
/// serialization cost is irrelevant.
model NumberSequence {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String?  @map("branch_id") @db.Uuid
  /// shared/src/constants.ts SEQUENCE_KEYS, e.g. "sale_invoice".
  key            String   @db.VarChar(60)
  prefix         String   @default("") @db.VarChar(20)
  /// Next value to issue, allocated and incremented under a row lock.
  nextValue      Int      @default(1) @map("next_value")
  padding        Int      @default(6)
  /// Optional period segment (e.g. "2026") that resets numbering per year.
  periodKey      String?  @map("period_key") @db.VarChar(10)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([organizationId, branchId, key, periodKey])
  @@map("number_sequences")
}

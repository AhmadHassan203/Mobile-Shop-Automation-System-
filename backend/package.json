{
  "name": "@mobileshop/backend",
  "version": "0.1.0",
  "private": true,
  "description": "MobileShop OS production API — NestJS modular monolith.",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint src test --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project unit",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mobileshop/database": "workspace:*",
    "@mobileshop/shared": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/throttler": "6.5.0",
    "argon2": "0.44.0",
    "cookie-parser": "1.4.7",
    "dotenv": "17.2.4",
    "helmet": "8.3.0",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@nestjs/cli": "11.0.24",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.28",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.1",
    "eslint": "9.39.5",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "unplugin-swc": "1.5.7",
    "vitest": "4.1.10"
  }
}

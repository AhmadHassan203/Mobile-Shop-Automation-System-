# =============================================================================
# MobileShop OS — environment template
# =============================================================================
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Every value below is a placeholder: no real secret belongs in this file.
# This combined file is a local developer convenience only. Each process parses
# an explicit allow-list: the API cannot load migration/seed/admin values, the
# Prisma CLI loads only migration URLs, and the seed loads only runtime + seed
# values. Production must inject separate per-process environments and must not
# deploy or mount the repository-root `.env`.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
TZ=UTC

# --- Database ----------------------------------------------------------------
# The application connects with a least-privilege role (NOT the postgres superuser).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://mobileshop_app:CHANGE_ME@localhost:5432/mobileshop_dev?schema=public

# Prisma CLI only. The backend must never receive this DDL-capable credential.
MIGRATION_DATABASE_URL=postgresql://mobileshop_migrator:CHANGE_ME@localhost:5432/mobileshop_dev?schema=public
SHADOW_DATABASE_URL=postgresql://mobileshop_migrator:CHANGE_ME@localhost:5432/mobileshop_shadow?schema=public

# Separate database used by integration tests. It is dropped/recreated freely,
# so it must never point at development or production data.
TEST_DATABASE_URL=postgresql://mobileshop_app:CHANGE_ME@localhost:5432/mobileshop_test?schema=public
TEST_MIGRATION_DATABASE_URL=postgresql://mobileshop_migrator:CHANGE_ME@localhost:5432/mobileshop_test?schema=public

# Mandatory readiness probe budget. A database outage must return 503 quickly.
DATABASE_HEALTH_TIMEOUT_MS=2000

# Used only by scripts/ provisioning helpers to create the app role/database.
# Leave blank in normal development.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=

# --- Backend API -------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
API_GLOBAL_PREFIX=api
CORS_ORIGIN=http://localhost:3000
API_RATE_LIMIT_TTL_SECONDS=60
API_RATE_LIMIT_MAX_REQUESTS=300

# --- Sessions / security -----------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_32_BYTE_HEX_SECRET
SESSION_TTL_HOURS=12
SESSION_COOKIE_NAME=mshop_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Authentication rate limiting
AUTH_RATE_LIMIT_TTL_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# --- Business configuration --------------------------------------------------
BUSINESS_TIMEZONE=Asia/Karachi
BUSINESS_CURRENCY=PKR
BUSINESS_CURRENCY_MINOR_UNITS=2

# --- Frontend ----------------------------------------------------------------
# Put these public values in `frontend/.env.local` for overrides. The frontend
# never loads the combined root file; localhost defaults work without a file.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=MobileShop OS

# --- Seeding -----------------------------------------------------------------
# Non-production bootstrap owner. Seeding accepts only NODE_ENV=development or test.
SEED_OWNER_EMAIL=owner@mobileshop.local
SEED_OWNER_PASSWORD=CHANGE_ME_DEV_ONLY

# --- Observability -----------------------------------------------------------
LOG_LEVEL=debug
LOG_PRETTY=true
SENTRY_DSN=

# --- Object storage (adapter; local filesystem used until configured) ---------
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./.storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

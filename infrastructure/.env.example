# Copy this file to infrastructure/.env. The destination is git-ignored.
# These are local-only placeholders; never reuse local credentials elsewhere.

POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_PORT=5432
# Keep this bootstrap superuser distinct from both application roles below.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_LOCAL_SUPERUSER_PASSWORD

# The backend receives only the runtime credential. Prisma CLI commands use
# the separate migration credential; use different generated values.
MOBILESHOP_APP_DB_PASSWORD=CHANGE_ME_LOCAL_APP_PASSWORD
MOBILESHOP_MIGRATOR_DB_PASSWORD=CHANGE_ME_LOCAL_MIGRATOR_PASSWORD

CADDY_IMAGE=caddy:2-alpine
PROXY_PORT=8080

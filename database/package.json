{
  "name": "@mobileshop/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, migrations, seeds and database utilities. All database work lives here.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "migrate:reset": "prisma migrate reset --force",
    "reset": "prisma migrate reset --force",
    "seed": "tsx seeds/index.ts",
    "studio": "prisma studio",
    "format": "prisma format",
    "validate": "prisma validate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run test/identity-migration.integration.spec.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "argon2": "0.44.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@mobileshop/shared": "workspace:*",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "dotenv": "17.2.4",
    "prisma": "7.8.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}

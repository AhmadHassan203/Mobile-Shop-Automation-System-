// =============================================================================
// MobileShop OS — Prisma schema
// =============================================================================
// All database work lives in database/ (13_ §19).
//
// Conventions applied throughout:
//   * Money is ALWAYS an integer number of minor units (paisa), named *_minor.
//     Never Float, never Decimal-for-money. (05_RULES.md §7, 13_ §23.11)
//   * Timestamps are stored UTC (@db.Timestamptz); Asia/Karachi is a display and
//     business-day concern handled in shared/src/datetime.ts. (05_RULES.md §9)
//   * organization_id / branch_id / location_id exist from day one even though
//     launch is single-branch, so multi-branch needs no data migration. (13_ §8)
//   * Constraints are enforced in the DATABASE, not only in the API. (13_ §4)
//   * Posted records are immutable; corrections use controlled workflows. (13_ §23.9)
//
// Slice 1 defines access, audit and system tables. Later slices add catalog,
// inventory, purchasing, sales, external services, cash and finance.
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

// Prisma 7 removed `url` from the datasource block. The connection string for
// Migrate now lives in prisma.config.ts, and the runtime client receives a
// driver adapter (@prisma/adapter-pg) instead. See database/README.md.
datasource db {
  provider = "postgresql"
}

// =============================================================================
// Organization, branch and stock location
// =============================================================================

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  /// ISO-4217. Stored even though PKR is the only launch currency
  /// (03_ARCHITECTURE.md §8).
  currency  String   @default("PKR") @db.Char(3)
  timezone  String   @default("Asia/Karachi") @db.VarChar(64)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  branches        Branch[]
  users           User[]
  roles           Role[]
  auditEvents     AuditEvent[]
  settings        ApplicationSetting[]
  numberSequences NumberSequence[]
  categories      Category[]
  brands          Brand[]
  productModels   ProductModel[]
  productVariants ProductVariant[]
  productAliases  ProductAlias[]
  productBarcodes ProductBarcode[]
  priceLists      PriceList[]
  priceEntries    PriceEntry[]

  serializedUnits    SerializedUnit[]
  deviceIdentifiers  DeviceIdentifier[]
  stockBatches       StockBatch[]
  inventoryMovements InventoryMovement[]

  suppliers               Supplier[]
  supplierContacts        SupplierContact[]
  purchaseOrders          PurchaseOrder[]
  purchaseOrderLines      PurchaseOrderLine[]
  goodsReceipts           GoodsReceipt[]
  goodsReceiptLines       GoodsReceiptLine[]
  goodsReceiptLandedCosts GoodsReceiptLandedCost[]
  payables                Payable[]

  customers          Customer[]
  cashSessions       CashSession[]
  financialAccounts  FinancialAccount[]
  sales              Sale[]
  saleLines          SaleLine[]
  payments           Payment[]
  paymentAllocations PaymentAllocation[]
  receivables        Receivable[]
  financialEntries   FinancialEntry[]
  saleReturns        SaleReturn[]
  returnLines        ReturnLine[]
  refunds            Refund[]

  demandRequests     DemandRequest[]
  demandRequestItems DemandRequestItem[]
  demandFollowUps    DemandFollowUp[]

  @@map("organizations")
}

model Branch {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  code           String   @db.VarChar(20)
  name           String   @db.VarChar(200)
  addressLine    String?  @map("address_line") @db.VarChar(300)
  city           String   @default("Lahore") @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  isDefault      Boolean  @default(false) @map("is_default")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  stockLocations  StockLocation[]
  scopeAccess     UserScopeAccess[]
  auditEvents     AuditEvent[]
  sessions        Session[]
  numberSequences NumberSequence[]
  settings        ApplicationSetting[]

  serializedUnits    SerializedUnit[]
  stockBatches       StockBatch[]
  inventoryMovements InventoryMovement[]

  purchaseOrders          PurchaseOrder[]
  goodsReceipts           GoodsReceipt[]
  goodsReceiptLines       GoodsReceiptLine[]
  goodsReceiptLandedCosts GoodsReceiptLandedCost[]
  payables                Payable[]

  priceEntries       PriceEntry[]
  cashSessions       CashSession[]
  financialAccounts  FinancialAccount[]
  sales              Sale[]
  saleLines          SaleLine[]
  payments           Payment[]
  paymentAllocations PaymentAllocation[]
  receivables        Receivable[]
  financialEntries   FinancialEntry[]
  saleReturns        SaleReturn[]
  returnLines        ReturnLine[]
  refunds            Refund[]

  demandRequests     DemandRequest[]
  demandRequestItems DemandRequestItem[]
  demandFollowUps    DemandFollowUp[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@index([organizationId, isActive])
  @@map("branches")
}

model StockLocation {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  branchId       String            @map("branch_id") @db.Uuid
  code           String            @db.VarChar(20)
  name           String            @db.VarChar(200)
  /// The public inventory contract calls this `locationType`; the column keeps
  /// the name migration 0001 applied.
  kind           StockLocationKind @default(store)
  /// Exactly one location per branch is the default receiving/selling location.
  isDefault      Boolean           @default(false) @map("is_default")
  isActive       Boolean           @default(true) @map("is_active")
  /// Optimistic concurrency token, added by 0007 so two managers editing one
  /// location cannot silently overwrite each other. A CHECK (> 0) guards it in
  /// SQL and is not expressible here.
  version        Int               @default(1)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  branch      Branch            @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  scopeAccess UserScopeAccess[]

  serializedUnits SerializedUnit[]
  stockBatches    StockBatch[]
  movements       InventoryMovement[]
  receiptLines    GoodsReceiptLine[]
  saleLines       SaleLine[]
  returnLines     ReturnLine[]

  @@unique([organizationId, branchId, code])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, isActive])
  @@map("stock_locations")
}

/// Physical and virtual stock locations (01_PRD.md §5.4).
enum StockLocationKind {
  store
  warehouse
  /// Non-physical holding areas: quarantine, repair bench, in-transit.
  virtual
}

// =============================================================================
// Catalog
// =============================================================================

/// Category/subcategory tree. Products remain inactive rather than being
/// deleted once historical transactions reference them (05_RULES.md §2).
model Category {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  parentCategoryId String?  @map("parent_category_id") @db.Uuid
  name             String   @db.VarChar(200)
  slug             String   @db.VarChar(220)
  isActive         Boolean  @default(true) @map("is_active")
  /// Optimistic concurrency token. A self-parent check and a cycle-rejecting
  /// trigger guard the tree in SQL (0006); neither is expressible here.
  version          Int      @default(1)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parent        Category?      @relation("CategoryTree", fields: [parentCategoryId, organizationId], references: [id, organizationId], onDelete: Restrict)
  children      Category[]     @relation("CategoryTree")
  productModels ProductModel[]

  @@unique([organizationId, slug])
  @@unique([id, organizationId])
  @@index([organizationId, parentCategoryId, isActive])
  @@map("categories")
}

model Brand {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(200)
  slug           String   @db.VarChar(220)
  isActive       Boolean  @default(true) @map("is_active")
  /// Optimistic concurrency token (0006).
  version        Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  productModels ProductModel[]

  @@unique([organizationId, slug])
  @@unique([id, organizationId])
  @@index([organizationId, isActive, name])
  @@map("brands")
}

model ProductModel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  brandId        String   @map("brand_id") @db.Uuid
  categoryId     String   @map("category_id") @db.Uuid
  name           String   @db.VarChar(200)
  canonicalName  String   @map("canonical_name") @db.VarChar(200)
  isActive       Boolean  @default(true) @map("is_active")
  /// Optimistic concurrency token (0006).
  version        Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  brand        Brand               @relation(fields: [brandId, organizationId], references: [id, organizationId], onDelete: Restrict)
  category     Category            @relation(fields: [categoryId, organizationId], references: [id, organizationId], onDelete: Restrict)
  variants     ProductVariant[]
  demandItems  DemandRequestItem[]

  @@unique([organizationId, brandId, canonicalName])
  @@unique([id, organizationId])
  @@index([organizationId, categoryId, isActive])
  @@index([organizationId, brandId, isActive])
  @@map("product_models")
}

/// Sellable definition. A serialized physical phone is a later
/// SerializedInventoryUnit, never a ProductVariant (04_DATA_MODEL.md §3).
model ProductVariant {
  id                String           @id @default(uuid()) @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  productModelId    String           @map("product_model_id") @db.Uuid
  sku               String           @db.VarChar(100)
  name              String           @db.VarChar(240)
  trackingType      TrackingType     @map("tracking_type")
  condition         ProductCondition
  ptaStatus         PtaStatus        @map("pta_status")
  ram               String?          @db.VarChar(100)
  storage           String?          @db.VarChar(100)
  color             String?          @db.VarChar(100)
  region            String?          @db.VarChar(100)
  warrantyType      WarrantyType     @default(none) @map("warranty_type")
  warrantyMonths    Int?             @map("warranty_months")
  attributes        Json?
  /// Reserved for the pricing slice. Catalog create cannot set these values.
  defaultPriceMinor BigInt?          @map("default_price_minor")
  minPriceMinor     BigInt?          @map("min_price_minor")
  reorderPoint      Int?             @map("reorder_point")
  casePackSize      Int?             @map("case_pack_size")
  isActive          Boolean          @default(true) @map("is_active")
  version           Int              @default(1)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  productModel ProductModel     @relation(fields: [productModelId, organizationId], references: [id, organizationId], onDelete: Restrict)
  aliases      ProductAlias[]
  barcodes     ProductBarcode[]

  serializedUnits    SerializedUnit[]
  stockBatches       StockBatch[]
  movements          InventoryMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines  GoodsReceiptLine[]
  priceEntries       PriceEntry[]
  saleLines          SaleLine[]
  returnLines        ReturnLine[]
  demandItems        DemandRequestItem[]

  @@unique([organizationId, sku])
  @@unique([id, organizationId])
  /// Supports the receipt-line FK that proves the caller's tracking type is
  /// the variant's stored tracking type rather than an untrusted body value.
  @@unique([id, organizationId, trackingType])
  @@index([organizationId, productModelId, isActive])
  @@index([organizationId, name])
  @@map("product_variants")
}

model ProductAlias {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  alias            String   @db.VarChar(200)
  normalizedAlias  String   @map("normalized_alias") @db.VarChar(200)
  source           String?  @db.VarChar(40)
  /// Aliases are retired, never deleted (the 0005 hard-delete trigger still
  /// applies). Uniqueness of `normalized_alias` is therefore a partial unique
  /// index `WHERE is_active` (0006) so a retired alias frees its value. Prisma
  /// cannot express a partial index, so it is intentionally absent below and
  /// enforced only in SQL.
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  productVariant ProductVariant @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, productVariantId])
  @@map("product_aliases")
}

model ProductBarcode {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  barcode          String   @db.VarChar(128)
  /// Vocabulary is intentionally deferred; the first public contract accepts
  /// the barcode value only and does not invent a barcode taxonomy.
  barcodeType      String?  @map("barcode_type") @db.VarChar(30)
  isPrimary        Boolean  @default(false) @map("is_primary")
  /// Barcodes are retired, never deleted. As with aliases, uniqueness of
  /// `barcode` is a partial unique index `WHERE is_active` (0006) and so cannot
  /// be declared here. SQL additionally checks that a retired barcode is never
  /// left flagged primary.
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  productVariant ProductVariant @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, productVariantId])
  @@map("product_barcodes")
}

// =============================================================================
// Inventory
// =============================================================================
// Balances are DERIVED from inventory_movements plus the unit and batch rows.
// There is deliberately no stored balance table: a cached total is one bug away
// from disagreeing with the ledger that produced it (04_DATA_MODEL.md §5).

/// One physical serialized device. A ProductVariant is the sellable definition;
/// this is the handset on the shelf (04_DATA_MODEL.md §3).
model SerializedUnit {
  id                  String               @id @default(uuid()) @db.Uuid
  organizationId      String               @map("organization_id") @db.Uuid
  branchId            String               @map("branch_id") @db.Uuid
  productVariantId    String               @map("product_variant_id") @db.Uuid
  stockLocationId     String               @map("stock_location_id") @db.Uuid
  /// Purchasing provenance is nullable only for pre-0008 stock and controlled
  /// non-purchase acquisition workflows. SQL requires both values together and
  /// the receipt-line composite FK proves immutable source/variant consistency.
  /// Current branch/location deliberately stay outside that FK so movements can
  /// relocate a received handset without rewriting its receipt provenance.
  purchaseOrderLineId String?              @map("purchase_order_line_id") @db.Uuid
  goodsReceiptLineId  String?              @map("goods_receipt_line_id") @db.Uuid
  state               SerializedStockState
  condition           ProductCondition
  ptaStatus           PtaStatus            @map("pta_status")
  receivedAt          DateTime?            @map("received_at") @db.Timestamptz(3)
  /// Reserved for the purchasing slice, which owns cost. The inventory API
  /// neither accepts nor exposes these values: no inventory request can set
  /// them and no inventory response carries them (shared/src/inventory.ts).
  /// SQL requires financially posted receipt units to have both values plus
  /// receivedAt, and any landed value must be at least the actual value.
  actualCostMinor     BigInt?              @map("actual_cost_minor")
  landedCostMinor     BigInt?              @map("landed_cost_minor")
  /// Optimistic concurrency token; CHECK (> 0) lives in SQL (0007).
  version             Int                  @default(1)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch            Branch             @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  productVariant    ProductVariant     @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId, organizationId, productVariantId], references: [id, organizationId, productVariantId], onDelete: Restrict)
  goodsReceiptLine  GoodsReceiptLine?  @relation(fields: [goodsReceiptLineId, organizationId, productVariantId, purchaseOrderLineId], references: [id, organizationId, productVariantId, purchaseOrderLineId], onDelete: Restrict)
  /// Keyed on (id, organization_id, branch_id) rather than (id, organization_id):
  /// this is what forces a unit's branch to agree with its location's branch.
  stockLocation     StockLocation      @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)

  identifiers DeviceIdentifier[]
  movements   InventoryMovement[]
  saleLines   SaleLine[]
  returnLines ReturnLine[]

  @@unique([id, organizationId])
  @@unique([id, organizationId, branchId, productVariantId, stockLocationId])
  @@index([organizationId, productVariantId, state])
  @@index([organizationId, stockLocationId, state])
  @@index([organizationId, receivedAt])
  @@map("serialized_units")
}

/// The IMEI-uniqueness backbone.
///
/// A separate table rather than imei1/imei2/serial columns on the unit, so that
/// every identifier shares ONE uniqueness namespace per organization: the same
/// IMEI cannot be imei1 on one handset and imei2 on another (05_RULES.md §1.1).
model DeviceIdentifier {
  id               String               @id @default(uuid()) @db.Uuid
  organizationId   String               @map("organization_id") @db.Uuid
  serializedUnitId String               @map("serialized_unit_id") @db.Uuid
  identifierType   DeviceIdentifierType @map("identifier_type")
  /// Stable slot identity: IMEI 1/2 and serial 1. SQL backfills legacy rows,
  /// constrains the valid type/position combinations and freezes identifiers
  /// once their serialized unit is linked to a posted goods receipt (0009).
  position         Int                  @db.SmallInt
  /// Normalized form (shared/src/imei.ts normalizeImei/normalizeSerial), so
  /// "356938-035643809" and "356938035643809" collide instead of both entering
  /// stock. A CHECK constrains it to the normalized alphabet.
  normalizedValue  String               @map("normalized_value") @db.VarChar(64)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  serializedUnit SerializedUnit @relation(fields: [serializedUnitId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, normalizedValue])
  @@unique([serializedUnitId, identifierType, position], map: "device_identifiers_unit_type_position_key")
  @@index([organizationId, serializedUnitId])
  @@map("device_identifiers")
}

/// Quantity-tracked stock: one row per variant per location.
model StockBatch {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  branchId         String    @map("branch_id") @db.Uuid
  productVariantId String    @map("product_variant_id") @db.Uuid
  stockLocationId  String    @map("stock_location_id") @db.Uuid
  /// CHECK (>= 0) in SQL: 13_ §23 blocks negative stock at the database, not
  /// merely in the API.
  quantityOnHand   Int       @default(0) @map("quantity_on_hand")
  /// CHECK (>= 0 AND <= quantity_on_hand) in SQL.
  quantityReserved Int       @default(0) @map("quantity_reserved")
  /// Current moving weighted-average unit costs (ASM-005), not historical
  /// receipt evidence. Exact received costs remain on immutable receipt lines.
  /// Both NULL means explicitly uncosted; otherwise both must be present and
  /// landed cost must be at least actual cost.
  actualCostMinor  BigInt?   @map("actual_cost_minor")
  landedCostMinor  BigInt?   @map("landed_cost_minor")
  receivedAt       DateTime? @map("received_at") @db.Timestamptz(3)
  /// Optimistic concurrency token; CHECK (> 0) lives in SQL (0007).
  version          Int       @default(1)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch         Branch         @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  productVariant ProductVariant @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  stockLocation  StockLocation  @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)

  movements    InventoryMovement[]
  receiptLines GoodsReceiptLine[]

  @@unique([organizationId, productVariantId, stockLocationId])
  @@unique([id, organizationId])
  /// Receipt lines use this key so a named aggregate bucket cannot belong to a
  /// different branch, variant or location than the stock it receives.
  @@unique([id, organizationId, branchId, productVariantId, stockLocationId])
  @@map("stock_batches")
}

/// The append-only inventory ledger (04_DATA_MODEL.md §5).
///
/// Never updated or deleted: a correction is a new compensating movement. A
/// BEFORE UPDATE OR DELETE OR TRUNCATE trigger and an explicit REVOKE enforce
/// that at the database, not merely by convention (0007).
///
/// Direction is carried by `movement_type` through MOVEMENT_ON_HAND_SIGN, never
/// by a negative quantity — CHECK (quantity > 0) makes that unrepresentable.
model InventoryMovement {
  id               String                @id @default(uuid()) @db.Uuid
  organizationId   String                @map("organization_id") @db.Uuid
  branchId         String                @map("branch_id") @db.Uuid
  productVariantId String                @map("product_variant_id") @db.Uuid
  /// Exactly one of serialized_unit_id / stock_batch_id is set; a CHECK with
  /// `<>` over the two NULL tests enforces the exclusivity in SQL.
  serializedUnitId String?               @map("serialized_unit_id") @db.Uuid
  stockBatchId     String?               @map("stock_batch_id") @db.Uuid
  stockLocationId  String                @map("stock_location_id") @db.Uuid
  movementType     MovementType          @map("movement_type")
  quantity         Int
  /// Set only for serialized movements; a CHECK keeps them NULL otherwise.
  fromState        SerializedStockState? @map("from_state")
  toState          SerializedStockState? @map("to_state")
  referenceType    String?               @map("reference_type") @db.VarChar(40)
  referenceId      String?               @map("reference_id") @db.Uuid
  reason           String?               @db.VarChar(500)
  actorUserId      String                @map("actor_user_id") @db.Uuid
  occurredAt       DateTime              @default(now()) @map("occurred_at") @db.Timestamptz(3)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch         Branch          @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  productVariant ProductVariant  @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  serializedUnit SerializedUnit? @relation(fields: [serializedUnitId, organizationId], references: [id, organizationId], onDelete: Restrict)
  stockBatch     StockBatch?     @relation(fields: [stockBatchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  stockLocation  StockLocation   @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  actor          User            @relation("InventoryMovementActor", fields: [actorUserId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, productVariantId, occurredAt])
  @@index([organizationId, serializedUnitId, occurredAt])
  @@index([organizationId, movementType, occurredAt])
  @@index([referenceType, referenceId])
  @@map("inventory_movements")
}

/// Serialized device lifecycle (05_RULES.md §3). Order and values mirror
/// shared/src/enums.ts SERIALIZED_STOCK_STATES exactly; allowed transitions are
/// decided by isTransitionAllowed() in the domain service.
enum SerializedStockState {
  pending_verification
  quarantined
  available
  reserved
  sold
  returned_inspection
  defective
  supplier_warranty
  customer_warranty
  repair
  written_off
  purchase_returned
}

/// Mirrors shared/src/enums.ts MOVEMENT_TYPES exactly (04_DATA_MODEL.md §5).
enum MovementType {
  purchase_receive
  sale
  sale_return
  purchase_return
  transfer_out
  transfer_in
  reserve
  release
  adjustment_in
  adjustment_out
  damage
  write_off
  repair_issue
  repair_return
}

/// IMEI and serial share one uniqueness namespace, so the kind is a column
/// rather than a separate table (shared/src/inventory.ts DEVICE_IDENTIFIER_TYPES).
enum DeviceIdentifierType {
  imei
  serial
}

enum TrackingType {
  serialized
  quantity
}

enum ProductCondition {
  new
  used
  open_box
  refurbished
}

enum PtaStatus {
  pta_approved
  non_pta
  pta_pending
  not_applicable
  unknown
}

enum WarrantyType {
  official
  local
  shop
  none
  supplier
}

// =============================================================================
// Suppliers, purchasing, receiving and payable creation
// =============================================================================

/// Organization-level supplier master. Suppliers are deactivated, never
/// deleted, because posted purchase records retain their identity forever.
model Supplier {
  id                    String   @id @default(uuid()) @db.Uuid
  organizationId        String   @map("organization_id") @db.Uuid
  /// Normalized by shared/src/purchasing.ts before write. SQL pins the same
  /// alphabet and a tenant-scoped unique index is the final duplicate guard.
  code                  String   @db.VarChar(40)
  name                  String   @db.VarChar(200)
  paymentTermsDays      Int      @default(0) @map("payment_terms_days")
  leadTimeDays          Int      @default(0) @map("lead_time_days")
  onTimeRateBasisPoints Int?     @map("on_time_rate_basis_points")
  addressLine           String?  @map("address_line") @db.VarChar(300)
  city                  String?  @db.VarChar(100)
  notes                 String?  @db.VarChar(500)
  isActive              Boolean  @default(true) @map("is_active")
  version               Int      @default(1)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  contacts       SupplierContact[]
  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]
  payables       Payable[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@index([organizationId, isActive, name])
  @@map("suppliers")
}

/// Replace-semantics supplier contacts. Old contacts are retired with
/// is_active so historical references and audit snapshots are never orphaned.
model SupplierContact {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  supplierId     String   @map("supplier_id") @db.Uuid
  name           String   @db.VarChar(200)
  role           String?  @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  email          String?  @db.VarChar(255)
  isPrimary      Boolean  @default(false) @map("is_primary")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  supplier     Supplier     @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@index([organizationId, supplierId, isActive])
  /// Exactly one active primary contact is a partial unique index in 0008;
  /// Prisma cannot represent the WHERE predicate.
  @@map("supplier_contacts")
}

/// A purchase order is commercial intent only. It never creates stock; the
/// immutable goods receipt below is the transaction that does (05_RULES §1.5).
model PurchaseOrder {
  id                 String              @id @default(uuid()) @db.Uuid
  organizationId     String              @map("organization_id") @db.Uuid
  branchId           String              @map("branch_id") @db.Uuid
  supplierId         String              @map("supplier_id") @db.Uuid
  createdByUserId    String              @map("created_by_user_id") @db.Uuid
  approvedByUserId   String?             @map("approved_by_user_id") @db.Uuid
  orderedByUserId    String?             @map("ordered_by_user_id") @db.Uuid
  closedByUserId     String?             @map("closed_by_user_id") @db.Uuid
  cancelledByUserId  String?             @map("cancelled_by_user_id") @db.Uuid
  number             String              @db.VarChar(100)
  status             PurchaseOrderStatus @default(draft)
  orderDate          DateTime            @default(dbgenerated("CURRENT_DATE")) @map("order_date") @db.Date
  expectedOn         DateTime?           @map("expected_on") @db.Date
  notes              String?             @db.VarChar(500)
  approvedAt         DateTime?           @map("approved_at") @db.Timestamptz(3)
  orderedAt          DateTime?           @map("ordered_at") @db.Timestamptz(3)
  closedAt           DateTime?           @map("closed_at") @db.Timestamptz(3)
  cancelledAt        DateTime?           @map("cancelled_at") @db.Timestamptz(3)
  cancellationReason String?             @map("cancellation_reason") @db.VarChar(500)
  version            Int                 @default(1)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch              @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  supplier     Supplier            @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdBy    User                @relation("PurchaseOrderCreator", fields: [createdByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  approvedBy   User?               @relation("PurchaseOrderApprover", fields: [approvedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  orderedBy    User?               @relation("PurchaseOrderOrderer", fields: [orderedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  closedBy     User?               @relation("PurchaseOrderCloser", fields: [closedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  cancelledBy  User?               @relation("PurchaseOrderCanceller", fields: [cancelledByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lines        PurchaseOrderLine[]
  receipts     GoodsReceipt[]

  @@unique([organizationId, branchId, number])
  @@unique([id, organizationId])
  @@unique([id, organizationId, branchId, supplierId])
  @@index([organizationId, branchId, status, orderDate])
  @@index([organizationId, supplierId, orderDate])
  @@map("purchase_orders")
}

/// Ordered and received quantities share a row so `received <= ordered` has a
/// database CHECK backstop. Exact ordered cost is never inferred from catalog.
model PurchaseOrderLine {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  purchaseOrderId  String   @map("purchase_order_id") @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  lineNumber       Int      @map("line_number")
  quantityOrdered  Int      @map("quantity_ordered")
  quantityReceived Int      @default(0) @map("quantity_received")
  unitCostMinor    BigInt   @map("unit_cost_minor")
  notes            String?  @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId, organizationId], references: [id, organizationId], onDelete: Restrict)
  productVariant  ProductVariant     @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  receiptLines    GoodsReceiptLine[]
  serializedUnits SerializedUnit[]

  @@unique([organizationId, purchaseOrderId, lineNumber])
  @@unique([organizationId, purchaseOrderId, productVariantId])
  @@unique([id, organizationId])
  @@unique([id, organizationId, productVariantId])
  @@unique([id, organizationId, purchaseOrderId, productVariantId])
  @@index([organizationId, productVariantId])
  @@map("purchase_order_lines")
}

/// Immutable proof that stock actually arrived. All totals are calculated by
/// the server in TXN-1 and rechecked against immutable child rows at COMMIT.
model GoodsReceipt {
  id                         String                     @id @default(uuid()) @db.Uuid
  organizationId             String                     @map("organization_id") @db.Uuid
  branchId                   String                     @map("branch_id") @db.Uuid
  purchaseOrderId            String                     @map("purchase_order_id") @db.Uuid
  supplierId                 String                     @map("supplier_id") @db.Uuid
  receivedByUserId           String                     @map("received_by_user_id") @db.Uuid
  number                     String                     @db.VarChar(100)
  supplierInvoiceReference   String?                    @map("supplier_invoice_reference") @db.VarChar(100)
  receivedAt                 DateTime                   @default(now()) @map("received_at") @db.Timestamptz(3)
  invoiceDueOn               DateTime                   @map("invoice_due_on") @db.Date
  notes                      String?                    @db.VarChar(500)
  landedCostAllocationMethod LandedCostAllocationMethod @default(by_value) @map("landed_cost_allocation_method")
  actualCostTotalMinor       BigInt                     @map("actual_cost_total_minor")
  landedCostTotalMinor       BigInt                     @map("landed_cost_total_minor")
  payableTotalMinor          BigInt                     @map("payable_total_minor")
  /// Optional for legacy receipts. New idempotent posting requests persist the
  /// client key with a lowercase SHA-256 hash of the canonical request (0010).
  idempotencyKey             String?                    @map("idempotency_key") @db.Uuid
  requestHash                String?                    @map("request_hash") @db.Char(64)
  /// Child rows must be inserted in this same transaction; the trigger in
  /// 0008 rejects a later INSERT that would rewrite posted receipt history.
  postingTxid                BigInt                     @default(dbgenerated("txid_current()")) @map("posting_txid")
  createdAt                  DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)

  organization  Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch        Branch                   @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  supplier      Supplier                 @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)
  purchaseOrder PurchaseOrder            @relation(fields: [purchaseOrderId, organizationId, branchId, supplierId], references: [id, organizationId, branchId, supplierId], onDelete: Restrict)
  receivedBy    User                     @relation("GoodsReceiptReceiver", fields: [receivedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lines         GoodsReceiptLine[]
  landedCosts   GoodsReceiptLandedCost[]
  payable       Payable?

  @@unique([organizationId, branchId, number])
  @@unique([organizationId, branchId, idempotencyKey], map: "goods_receipts_idempotency_scope_key")
  @@unique([id, organizationId])
  @@unique([id, organizationId, branchId])
  @@unique([id, organizationId, branchId, purchaseOrderId])
  @@unique([id, organizationId, branchId, supplierId])
  @@index([organizationId, purchaseOrderId, receivedAt])
  @@index([organizationId, supplierId, receivedAt])
  @@map("goods_receipts")
}

/// Immutable exact received-cost evidence. Quantity stock points at the one
/// aggregate bucket it updated; serialized stock points back here from each
/// unit instead. The source FKs prove the receipt, PO line, variant and
/// destination all describe the same tenant-scoped arrival.
model GoodsReceiptLine {
  id                       String       @id @default(uuid()) @db.Uuid
  organizationId           String       @map("organization_id") @db.Uuid
  branchId                 String       @map("branch_id") @db.Uuid
  goodsReceiptId           String       @map("goods_receipt_id") @db.Uuid
  purchaseOrderId          String       @map("purchase_order_id") @db.Uuid
  purchaseOrderLineId      String       @map("purchase_order_line_id") @db.Uuid
  productVariantId         String       @map("product_variant_id") @db.Uuid
  stockLocationId          String       @map("stock_location_id") @db.Uuid
  trackingType             TrackingType @map("tracking_type")
  quantityReceived         Int          @map("quantity_received")
  unitCostMinor            BigInt       @map("unit_cost_minor")
  actualCostTotalMinor     BigInt       @map("actual_cost_total_minor")
  landedCostAllocatedMinor BigInt       @map("landed_cost_allocated_minor")
  landedCostTotalMinor     BigInt       @map("landed_cost_total_minor")
  stockBatchId             String?      @map("stock_batch_id") @db.Uuid
  createdAt                DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch            Branch            @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  goodsReceipt      GoodsReceipt      @relation(fields: [goodsReceiptId, organizationId, branchId, purchaseOrderId], references: [id, organizationId, branchId, purchaseOrderId], onDelete: Restrict)
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId, organizationId, purchaseOrderId, productVariantId], references: [id, organizationId, purchaseOrderId, productVariantId], onDelete: Restrict)
  productVariant    ProductVariant    @relation(fields: [productVariantId, organizationId, trackingType], references: [id, organizationId, trackingType], onDelete: Restrict)
  stockLocation     StockLocation     @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  stockBatch        StockBatch?       @relation(fields: [stockBatchId, organizationId, branchId, productVariantId, stockLocationId], references: [id, organizationId, branchId, productVariantId, stockLocationId], onDelete: Restrict)
  serializedUnits   SerializedUnit[]

  @@unique([organizationId, goodsReceiptId, purchaseOrderLineId, stockLocationId])
  @@unique([id, organizationId])
  /// Immutable source key for serialized provenance. Receiving destination is
  /// evidence on this row, not part of the unit's mutable current-location FK.
  @@unique([id, organizationId, productVariantId, purchaseOrderLineId])
  @@index([organizationId, purchaseOrderLineId])
  @@index([organizationId, productVariantId, createdAt])
  @@map("goods_receipt_lines")
}

/// Freight, customs, insurance and other landed-cost components. Entries are
/// immutable and their sum must equal receipt allocations at transaction end.
model GoodsReceiptLandedCost {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  branchId       String         @map("branch_id") @db.Uuid
  goodsReceiptId String         @map("goods_receipt_id") @db.Uuid
  kind           LandedCostKind
  amountMinor    BigInt         @map("amount_minor")
  reference      String?        @db.VarChar(100)
  notes          String?        @db.VarChar(500)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@index([organizationId, goodsReceiptId])
  @@map("goods_receipt_landed_costs")
}

/// Product-invoice obligation created atomically by receiving. Landed-cost
/// entries increase inventory value but are not owed to the product supplier;
/// settlement extends this row later while its source and amount stay fixed.
model Payable {
  id               String        @id @default(uuid()) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  branchId         String        @map("branch_id") @db.Uuid
  supplierId       String        @map("supplier_id") @db.Uuid
  goodsReceiptId   String        @map("goods_receipt_id") @db.Uuid
  dueOn            DateTime      @map("due_on") @db.Date
  amountMinor      BigInt        @map("amount_minor")
  paidMinor        BigInt        @default(0) @map("paid_minor")
  outstandingMinor BigInt        @map("outstanding_minor")
  status           PayableStatus @default(open)
  version          Int           @default(1)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  supplier     Supplier     @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)
  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId, organizationId, branchId, supplierId], references: [id, organizationId, branchId, supplierId], onDelete: Restrict)

  @@unique([organizationId, goodsReceiptId])
  @@unique([goodsReceiptId, organizationId, branchId, supplierId])
  @@unique([id, organizationId])
  @@index([organizationId, supplierId, status, dueOn])
  @@index([organizationId, status, dueOn])
  @@map("payables")
}

enum PurchaseOrderStatus {
  draft
  approved
  ordered
  partially_received
  received
  closed
  cancelled
}

enum LandedCostKind {
  freight
  customs
  insurance
  handling
  tax
  other
}

enum LandedCostAllocationMethod {
  by_value
}

enum PayableStatus {
  open
  partially_paid
  paid
  cancelled
}

// =============================================================================
// Pricing, customers, sales, settlement and the minimal financial ledger
// =============================================================================

/// A named, tenant-scoped selling-price policy. Price lists are retired rather
/// than deleted; dated entries below preserve every price used by a sale.
model PriceList {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  code           String    @db.VarChar(40)
  name           String    @db.VarChar(160)
  effectiveFrom  DateTime  @default(now()) @map("effective_from") @db.Timestamptz(3)
  effectiveTo    DateTime? @map("effective_to") @db.Timestamptz(3)
  isActive       Boolean   @default(true) @map("is_active")
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  entries      PriceEntry[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@index([organizationId, isActive, effectiveFrom])
  @@map("price_lists")
}

/// Immutable dated price evidence. Changing a price creates a new row; a sale
/// copies the exact price into its line and may retain this source row's id.
model PriceEntry {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  branchId         String?   @map("branch_id") @db.Uuid
  priceListId      String    @map("price_list_id") @db.Uuid
  productVariantId String    @map("product_variant_id") @db.Uuid
  priceMinor       BigInt    @map("price_minor")
  minPriceMinor    BigInt?   @map("min_price_minor")
  effectiveFrom    DateTime  @map("effective_from") @db.Timestamptz(3)
  effectiveTo      DateTime? @map("effective_to") @db.Timestamptz(3)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch         Branch?        @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  priceList      PriceList      @relation(fields: [priceListId, organizationId], references: [id, organizationId], onDelete: Restrict)
  productVariant ProductVariant @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  saleLines      SaleLine[]

  @@unique([organizationId, priceListId, productVariantId, branchId, effectiveFrom])
  @@unique([id, organizationId, productVariantId])
  @@index([organizationId, productVariantId, effectiveFrom])
  @@index([organizationId, branchId, productVariantId, effectiveFrom(sort: Desc)], map: "price_entries_effective_branch_lookup_idx")
  @@map("price_entries")
}

/// A real customer master. Walk-in sales deliberately use a NULL customer_id
/// and an immutable name snapshot; no synthetic "walk-in customer" row exists.
model Customer {
  id               String                         @id @default(uuid()) @db.Uuid
  organizationId   String                         @map("organization_id") @db.Uuid
  customerNumber   String                         @map("customer_number") @db.VarChar(60)
  fullName         String                         @map("full_name") @db.VarChar(200)
  phoneE164        String?                        @map("phone_e164") @db.VarChar(20)
  phoneRaw         String?                        @map("phone_raw") @db.VarChar(40)
  email            String?                        @db.VarChar(255)
  marketingConsent CustomerMarketingConsentStatus @default(pending) @map("marketing_consent")
  addressLine      String?                        @map("address_line") @db.VarChar(500)
  creditLimitMinor BigInt                         @default(0) @map("credit_limit_minor")
  notes            String?                        @db.VarChar(1000)
  isActive         Boolean                        @default(true) @map("is_active")
  deletedAt        DateTime?                      @map("deleted_at") @db.Timestamptz(3)
  version          Int                            @default(1)
  createdAt        DateTime                       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sales          Sale[]
  payments       Payment[]
  receivables    Receivable[]
  saleReturns    SaleReturn[]
  demandRequests DemandRequest[]

  @@unique([organizationId, customerNumber])
  @@unique([id, organizationId])
  @@index([organizationId, isActive, fullName])
  @@map("customers")
}

/// Minimal drawer lifecycle required by cash sales. Closing evidence remains a
/// later child table so reopening can never overwrite an earlier count.
model CashSession {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  branchId         String            @map("branch_id") @db.Uuid
  sessionNumber    String            @map("session_number") @db.VarChar(100)
  cashierUserId    String            @map("cashier_user_id") @db.Uuid
  openedByUserId   String            @map("opened_by_user_id") @db.Uuid
  status           CashSessionStatus @default(open)
  openingCashMinor BigInt            @map("opening_cash_minor")
  openedAt         DateTime          @default(now()) @map("opened_at") @db.Timestamptz(3)
  closedAt         DateTime?         @map("closed_at") @db.Timestamptz(3)
  businessDate     DateTime          @map("business_date") @db.Date
  version          Int               @default(1)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  cashier      User         @relation("CashSessionCashier", fields: [cashierUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  openedBy     User         @relation("CashSessionOpener", fields: [openedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sales        Sale[]
  payments     Payment[]
  refunds      Refund[]

  @@unique([organizationId, branchId, sessionNumber])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, businessDate])
  @@map("cash_sessions")
}

/// Branch-scoped chart-of-account row. Balances are always derived from the
/// immutable financial_entries ledger, never stored as a mutable counter here.
model FinancialAccount {
  id                       String                  @id @default(uuid()) @db.Uuid
  organizationId           String                  @map("organization_id") @db.Uuid
  branchId                 String                  @map("branch_id") @db.Uuid
  code                     String                  @db.VarChar(60)
  name                     String                  @db.VarChar(200)
  accountType              FinancialAccountType    @map("account_type")
  accountSubtype           FinancialAccountSubtype @map("account_subtype")
  normalBalance            LedgerDirection         @map("normal_balance")
  lowBalanceThresholdMinor BigInt?                 @map("low_balance_threshold_minor")
  isActive                 Boolean                 @default(true) @map("is_active")
  version                  Int                     @default(1)
  createdAt                DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch           @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  payments     Payment[]
  entries      FinancialEntry[]
  refunds      Refund[]

  @@unique([organizationId, branchId, code])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, accountSubtype, isActive])
  @@map("financial_accounts")
}

/// Sale header. Mutable only in draft; posting freezes the request evidence,
/// invoice, customer/walk-in snapshot and all exact financial totals.
model Sale {
  id                       String     @id @default(uuid()) @db.Uuid
  organizationId           String     @map("organization_id") @db.Uuid
  branchId                 String     @map("branch_id") @db.Uuid
  invoiceNumber            String?    @map("invoice_number") @db.VarChar(100)
  customerId               String?    @map("customer_id") @db.Uuid
  customerNameSnapshot     String     @map("customer_name_snapshot") @db.VarChar(200)
  customerPhoneSnapshot    String?    @map("customer_phone_snapshot") @db.VarChar(20)
  salespersonUserId        String     @map("salesperson_user_id") @db.Uuid
  cashierUserId            String     @map("cashier_user_id") @db.Uuid
  cashSessionId            String?    @map("cash_session_id") @db.Uuid
  status                   SaleStatus @default(draft)
  subtotalMinor            BigInt     @default(0) @map("subtotal_minor")
  discountMinor            BigInt     @default(0) @map("discount_minor")
  taxMinor                 BigInt     @default(0) @map("tax_minor")
  totalMinor               BigInt     @default(0) @map("total_minor")
  cogsMinor                BigInt     @default(0) @map("cogs_minor")
  grossProfitMinor         BigInt     @default(0) @map("gross_profit_minor")
  discountReason           String?    @map("discount_reason") @db.VarChar(500)
  note                     String?    @db.VarChar(500)
  discountApprovedByUserId String?    @map("discount_approved_by_user_id") @db.Uuid
  heldAt                   DateTime?  @map("held_at") @db.Timestamptz(3)
  heldByUserId             String?    @map("held_by_user_id") @db.Uuid
  cancelledAt              DateTime?  @map("cancelled_at") @db.Timestamptz(3)
  cancelledByUserId        String?    @map("cancelled_by_user_id") @db.Uuid
  cancellationReason       String?    @map("cancellation_reason") @db.VarChar(500)
  returnWindowDays         Int        @default(7) @map("return_window_days")
  postedAt                 DateTime?  @map("posted_at") @db.Timestamptz(3)
  businessDate             DateTime?  @map("business_date") @db.Date
  postRequestId            String?    @map("post_request_id") @db.Uuid
  postRequestHash          String?    @map("post_request_hash") @db.Char(64)
  /// Complete receipt evidence captured by the posting transaction. Nullable
  /// only so sales posted before migration 0012 retain a legacy live fallback.
  receiptSnapshot          Json?      @map("receipt_snapshot")
  version                  Int        @default(1)
  createdAt                DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch           Branch              @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  customer         Customer?           @relation(fields: [customerId, organizationId], references: [id, organizationId], onDelete: Restrict)
  salesperson      User                @relation("SaleSalesperson", fields: [salespersonUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  cashier          User                @relation("SaleCashier", fields: [cashierUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  cashSession      CashSession?        @relation(fields: [cashSessionId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  discountApprover User?               @relation("SaleDiscountApprover", fields: [discountApprovedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  heldBy           User?               @relation("SaleHolder", fields: [heldByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  cancelledBy      User?               @relation("SaleCanceller", fields: [cancelledByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lines            SaleLine[]
  allocations      PaymentAllocation[]
  receivable       Receivable?
  returns          SaleReturn[]        @relation("OriginalSaleReturns")
  returnLines      ReturnLine[]        @relation("ReturnLineSale")

  @@unique([organizationId, branchId, invoiceNumber])
  @@unique([organizationId, branchId, postRequestId])
  @@unique([id, organizationId])
  @@unique([id, organizationId, branchId])
  @@unique([id, organizationId, branchId, customerId])
  @@index([organizationId, branchId, businessDate, postedAt])
  @@index([organizationId, customerId, postedAt])
  @@map("sales")
}

/// Immutable posted product/identifier/price/cost/warranty snapshot. Draft
/// lines remain editable until the parent sale is posted in one transaction.
model SaleLine {
  id                     String       @id @default(uuid()) @db.Uuid
  organizationId         String       @map("organization_id") @db.Uuid
  branchId               String       @map("branch_id") @db.Uuid
  saleId                 String       @map("sale_id") @db.Uuid
  stockLocationId        String       @map("stock_location_id") @db.Uuid
  lineNumber             Int          @map("line_number")
  productVariantId       String       @map("product_variant_id") @db.Uuid
  priceEntryId           String?      @map("price_entry_id") @db.Uuid
  serializedUnitId       String?      @map("serialized_unit_id") @db.Uuid
  trackingTypeSnapshot   TrackingType @map("tracking_type_snapshot")
  productNameSnapshot    String       @map("product_name_snapshot") @db.VarChar(240)
  skuSnapshot            String       @map("sku_snapshot") @db.VarChar(100)
  imeiSnapshot           String?      @map("imei_snapshot") @db.VarChar(140)
  quantity               Int
  unitPriceMinor         BigInt       @map("unit_price_minor")
  priceVersionSnapshot   Int          @map("price_version_snapshot")
  discountMinor          BigInt       @default(0) @map("discount_minor")
  discountReason         String?      @map("discount_reason") @db.VarChar(500)
  taxMinor               BigInt       @default(0) @map("tax_minor")
  lineTotalMinor         BigInt       @map("line_total_minor")
  unitCogsMinor          BigInt       @map("unit_cogs_minor")
  cogsMinor              BigInt       @map("cogs_minor")
  grossProfitMinor       BigInt       @map("gross_profit_minor")
  warrantyTypeSnapshot   WarrantyType @map("warranty_type_snapshot")
  warrantyMonthsSnapshot Int?         @map("warranty_months_snapshot")
  isManualLine           Boolean      @default(false) @map("is_manual_line")
  unitSaleActive         Boolean      @default(false) @map("unit_sale_active")
  createdAt              DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch         Branch          @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sale           Sale            @relation(fields: [saleId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  stockLocation  StockLocation   @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  productVariant ProductVariant  @relation(fields: [productVariantId, organizationId, trackingTypeSnapshot], references: [id, organizationId, trackingType], onDelete: Restrict)
  priceEntry     PriceEntry?     @relation(fields: [priceEntryId, organizationId, productVariantId], references: [id, organizationId, productVariantId], onDelete: Restrict)
  serializedUnit SerializedUnit? @relation(fields: [serializedUnitId, organizationId, branchId, productVariantId, stockLocationId], references: [id, organizationId, branchId, productVariantId, stockLocationId], onDelete: Restrict)
  returnLines    ReturnLine[]

  @@unique([organizationId, saleId, lineNumber])
  @@unique([id, organizationId])
  @@unique([id, organizationId, saleId])
  @@index([organizationId, productVariantId])
  @@index([organizationId, serializedUnitId])
  @@map("sale_lines")
}

/// Return intake and refund header. Draft rows capture observed customer
/// evidence; posting freezes policy, settlement and approval evidence.
model SaleReturn {
  id                       String       @id @default(uuid()) @db.Uuid
  organizationId           String       @map("organization_id") @db.Uuid
  branchId                 String       @map("branch_id") @db.Uuid
  saleId                   String       @map("sale_id") @db.Uuid
  customerId               String?      @map("customer_id") @db.Uuid
  returnNumber             String?      @map("return_number") @db.VarChar(100)
  status                   ReturnStatus @default(draft)
  reason                   String       @db.VarChar(500)
  evidenceNote             String       @map("evidence_note") @db.VarChar(1000)
  totalRefundMinor         BigInt       @default(0) @map("total_refund_minor")
  totalCogsReversalMinor   BigInt       @default(0) @map("total_cogs_reversal_minor")
  receivableCreditMinor    BigInt       @default(0) @map("receivable_credit_minor")
  refundedMinor            BigInt       @default(0) @map("refunded_minor")
  returnWindowDaysSnapshot Int          @map("return_window_days_snapshot")
  returnDeadline           DateTime     @map("return_deadline") @db.Timestamptz(3)
  policyCheckedAt          DateTime     @map("policy_checked_at") @db.Timestamptz(3)
  policyExpired            Boolean      @map("policy_expired")
  policyOverridden         Boolean      @default(false) @map("policy_overridden")
  policyOverrideReason     String?      @map("policy_override_reason") @db.VarChar(500)
  policyOverriddenByUserId String?      @map("policy_overridden_by_user_id") @db.Uuid
  policyOverriddenAt       DateTime?    @map("policy_overridden_at") @db.Timestamptz(3)
  approvedByUserId         String?      @map("approved_by_user_id") @db.Uuid
  createdByUserId          String       @map("created_by_user_id") @db.Uuid
  postRequestId            String?      @map("post_request_id") @db.Uuid
  postRequestHash          String?      @map("post_request_hash") @db.Char(64)
  postedAt                 DateTime?    @map("posted_at") @db.Timestamptz(3)
  businessDate             DateTime?    @map("business_date") @db.Date
  version                  Int          @default(1)
  createdAt                DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch             Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sale               Sale         @relation("OriginalSaleReturns", fields: [saleId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  customer           Customer?    @relation(fields: [customerId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdBy          User         @relation("ReturnCreator", fields: [createdByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  approvedBy         User?        @relation("ReturnApprover", fields: [approvedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  policyOverriddenBy User?        @relation("ReturnPolicyOverrider", fields: [policyOverriddenByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lines              ReturnLine[]
  refund             Refund?

  @@unique([organizationId, branchId, returnNumber])
  @@unique([organizationId, branchId, postRequestId])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, status, createdAt(sort: Desc)])
  @@index([organizationId, saleId, status])
  @@index([organizationId, customerId, createdAt(sort: Desc)])
  @@map("returns")
}

/// Immutable original-sale allocation for a returned unit or quantity.
model ReturnLine {
  id                   String              @id @default(uuid()) @db.Uuid
  organizationId       String              @map("organization_id") @db.Uuid
  branchId             String              @map("branch_id") @db.Uuid
  returnId             String              @map("return_id") @db.Uuid
  saleId               String              @map("sale_id") @db.Uuid
  saleLineId           String              @map("sale_line_id") @db.Uuid
  productVariantId     String              @map("product_variant_id") @db.Uuid
  stockLocationId      String              @map("stock_location_id") @db.Uuid
  serializedUnitId     String?             @map("serialized_unit_id") @db.Uuid
  trackingTypeSnapshot TrackingType        @map("tracking_type_snapshot")
  productNameSnapshot  String              @map("product_name_snapshot") @db.VarChar(240)
  skuSnapshot          String              @map("sku_snapshot") @db.VarChar(100)
  identifierSnapshot   String?             @map("identifier_snapshot") @db.VarChar(140)
  quantity             Int
  refundMinor          BigInt              @map("refund_minor")
  cogsReversalMinor    BigInt              @map("cogs_reversal_minor")
  condition            ReturnItemCondition
  /// Null means inspection is pending; posting never invents an outcome.
  outcome              ReturnOutcome?
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch         Branch          @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  saleReturn     SaleReturn      @relation(fields: [returnId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  sale           Sale            @relation("ReturnLineSale", fields: [saleId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  saleLine       SaleLine        @relation(fields: [saleLineId, organizationId, saleId], references: [id, organizationId, saleId], onDelete: Restrict)
  productVariant ProductVariant  @relation(fields: [productVariantId, organizationId, trackingTypeSnapshot], references: [id, organizationId, trackingType], onDelete: Restrict)
  stockLocation  StockLocation   @relation(fields: [stockLocationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  serializedUnit SerializedUnit? @relation(fields: [serializedUnitId, organizationId, branchId, productVariantId, stockLocationId], references: [id, organizationId, branchId, productVariantId, stockLocationId], onDelete: Restrict)

  @@unique([organizationId, returnId, saleLineId])
  @@unique([organizationId, returnId, serializedUnitId])
  @@unique([id, organizationId])
  @@index([organizationId, saleId, saleLineId])
  @@index([organizationId, serializedUnitId])
  @@map("return_lines")
}

/// Immutable external refund evidence. Return credit against an outstanding
/// receivable is stored separately on the return/receivable, never as a refund.
model Refund {
  id                 String        @id @default(uuid()) @db.Uuid
  organizationId     String        @map("organization_id") @db.Uuid
  branchId           String        @map("branch_id") @db.Uuid
  returnId           String        @map("return_id") @db.Uuid
  refundNumber       String        @map("refund_number") @db.VarChar(100)
  paymentMethod      PaymentMethod @map("payment_method")
  amountMinor        BigInt        @map("amount_minor")
  financialAccountId String        @map("financial_account_id") @db.Uuid
  reference          String?       @db.VarChar(200)
  cashSessionId      String?       @map("cash_session_id") @db.Uuid
  refundedAt         DateTime      @default(now()) @map("refunded_at") @db.Timestamptz(3)
  businessDate       DateTime      @map("business_date") @db.Date
  processedByUserId  String        @map("processed_by_user_id") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch           Branch           @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  saleReturn       SaleReturn       @relation(fields: [returnId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  financialAccount FinancialAccount @relation(fields: [financialAccountId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  cashSession      CashSession?     @relation(fields: [cashSessionId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  processedBy      User             @relation("RefundProcessor", fields: [processedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, branchId, returnId])
  @@unique([returnId, organizationId, branchId])
  @@unique([organizationId, branchId, refundNumber])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, businessDate, refundedAt])
  @@map("refunds")
}

/// Immutable receipt of money. Every payment is allocated exactly once across
/// a sale or receivable inside the same organization and branch.
model Payment {
  id                 String        @id @default(uuid()) @db.Uuid
  organizationId     String        @map("organization_id") @db.Uuid
  branchId           String        @map("branch_id") @db.Uuid
  paymentNumber      String        @map("payment_number") @db.VarChar(100)
  customerId         String?       @map("customer_id") @db.Uuid
  paymentMethod      PaymentMethod @map("payment_method")
  amountMinor        BigInt        @map("amount_minor")
  financialAccountId String        @map("financial_account_id") @db.Uuid
  reference          String?       @db.VarChar(200)
  receivedAt         DateTime      @default(now()) @map("received_at") @db.Timestamptz(3)
  businessDate       DateTime      @map("business_date") @db.Date
  cashSessionId      String?       @map("cash_session_id") @db.Uuid
  receivedByUserId   String        @map("received_by_user_id") @db.Uuid
  idempotencyKey     String        @map("idempotency_key") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch           Branch              @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  customer         Customer?           @relation(fields: [customerId, organizationId], references: [id, organizationId], onDelete: Restrict)
  financialAccount FinancialAccount    @relation(fields: [financialAccountId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  cashSession      CashSession?        @relation(fields: [cashSessionId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  receivedBy       User                @relation("PaymentReceiver", fields: [receivedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  allocations      PaymentAllocation[]

  @@unique([organizationId, branchId, paymentNumber])
  @@unique([organizationId, branchId, idempotencyKey])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, businessDate, receivedAt])
  @@index([organizationId, cashSessionId])
  @@map("payments")
}

/// Customer credit created with a posted sale. Source and original amount are
/// immutable; only paid/balance/status/version advance during collection.
model Receivable {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  branchId         String           @map("branch_id") @db.Uuid
  customerId       String           @map("customer_id") @db.Uuid
  saleId           String           @map("sale_id") @db.Uuid
  amountMinor      BigInt           @map("amount_minor")
  paidMinor        BigInt           @default(0) @map("paid_minor")
  /// Return credit reduces debt without pretending the customer paid cash.
  creditedMinor    BigInt           @default(0) @map("credited_minor")
  balanceMinor     BigInt           @map("balance_minor")
  dueOn            DateTime         @map("due_on") @db.Date
  status           ReceivableStatus @default(open)
  approvedByUserId String           @map("approved_by_user_id") @db.Uuid
  version          Int              @default(1)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch              @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  customer     Customer            @relation(fields: [customerId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sale         Sale                @relation(fields: [saleId, organizationId, branchId, customerId], references: [id, organizationId, branchId, customerId], onDelete: Restrict)
  approvedBy   User                @relation("ReceivableApprover", fields: [approvedByUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  allocations  PaymentAllocation[]

  @@unique([organizationId, saleId])
  @@unique([saleId, organizationId, branchId, customerId])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, status, dueOn])
  @@index([organizationId, customerId, status])
  @@map("receivables")
}

/// One immutable allocation targets exactly one sale or one receivable.
model PaymentAllocation {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  paymentId      String   @map("payment_id") @db.Uuid
  saleId         String?  @map("sale_id") @db.Uuid
  receivableId   String?  @map("receivable_id") @db.Uuid
  amountMinor    BigInt   @map("amount_minor")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  payment      Payment      @relation(fields: [paymentId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  sale         Sale?        @relation(fields: [saleId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  receivable   Receivable?  @relation(fields: [receivableId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)

  @@unique([organizationId, paymentId, saleId])
  @@unique([organizationId, paymentId, receivableId])
  @@unique([id, organizationId])
  @@index([organizationId, saleId])
  @@index([organizationId, receivableId])
  @@map("payment_allocations")
}

/// Append-only financial ledger leg. Corrections are compensating entries;
/// source_key makes every posting leg idempotent across retries.
model FinancialEntry {
  id                 String                   @id @default(uuid()) @db.Uuid
  organizationId     String                   @map("organization_id") @db.Uuid
  branchId           String                   @map("branch_id") @db.Uuid
  entryGroupId       String                   @map("entry_group_id") @db.Uuid
  sourceType         FinancialEntrySourceType @map("source_type")
  sourceId           String?                  @map("source_id") @db.Uuid
  sourceKey          String                   @map("source_key") @db.VarChar(240)
  financialAccountId String                   @map("financial_account_id") @db.Uuid
  direction          LedgerDirection
  amountMinor        BigInt                   @map("amount_minor")
  description        String                   @db.VarChar(500)
  occurredAt         DateTime                 @default(now()) @map("occurred_at") @db.Timestamptz(3)
  businessDate       DateTime                 @map("business_date") @db.Date
  actorUserId        String                   @map("actor_user_id") @db.Uuid
  createdAt          DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch           Branch           @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  financialAccount FinancialAccount @relation(fields: [financialAccountId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  actor            User             @relation("FinancialEntryActor", fields: [actorUserId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, sourceKey])
  @@unique([id, organizationId])
  @@index([organizationId, financialAccountId, businessDate])
  @@index([organizationId, sourceType, sourceId])
  @@index([organizationId, entryGroupId])
  @@map("financial_entries")
}

/// Mirrors shared/src/enums.ts SALE_STATUSES exactly.
enum SaleStatus {
  draft
  posted
  cancelled
  partially_returned
  returned
}

/// Mirrors shared/src/enums.ts RETURN_STATUSES exactly.
enum ReturnStatus {
  draft
  posted
  cancelled
}

/// Physical condition observed during return intake.
enum ReturnItemCondition {
  like_new
  new
  used
  faulty
  damaged
}

/// Mirrors shared/src/enums.ts RETURN_OUTCOMES exactly.
enum ReturnOutcome {
  restock
  quarantine
  supplier_warranty
  write_off
  repair
}

/// Mirrors shared/src/enums.ts PAYMENT_METHODS exactly.
enum PaymentMethod {
  cash
  bank_transfer
  card
  digital_wallet
  credit
}

/// Mirrors shared/src/enums.ts CASH_SESSION_STATUSES exactly.
enum CashSessionStatus {
  open
  closing_pending
  closed
  reviewed
  reopened_with_authorization
}

/// Mirrors shared/src/enums.ts LEDGER_DIRECTIONS exactly.
enum LedgerDirection {
  debit
  credit
}

enum FinancialAccountType {
  asset
  liability
  equity
  revenue
  expense
}

enum FinancialAccountSubtype {
  physical_cash
  bank
  provider_float
  receivable
  inventory_asset
  sales_revenue
  sales_discount
  cost_of_goods_sold
  tax_payable
  other
}

enum FinancialEntrySourceType {
  sale
  return
  refund
  payment
  receivable
  opening_balance
}

enum ReceivableStatus {
  open
  partially_paid
  paid
  cancelled
}

/// Mirrors shared/src/customers.ts CUSTOMER_MARKETING_CONSENT_STATUSES.
enum CustomerMarketingConsentStatus {
  pending
  granted
  declined
  withdrawn
}

// =============================================================================
// Customer demand and missed-sale evidence
// =============================================================================

/// One customer interaction. Anonymous walk-ins deliberately carry neither a
/// customer id nor a phone. Request numbers are allocated by the server inside
/// the branch scope; version is the optimistic-concurrency token.
model DemandRequest {
  id                        String                           @id @default(uuid()) @db.Uuid
  organizationId            String                           @map("organization_id") @db.Uuid
  branchId                  String                           @map("branch_id") @db.Uuid
  requestNumber             String                           @map("request_number") @db.VarChar(40)
  customerId                String?                          @map("customer_id") @db.Uuid
  customerName              String?                          @map("customer_name") @db.VarChar(200)
  contactPhoneE164          String?                          @map("contact_phone_e164") @db.VarChar(20)
  quantity                  Int                              @default(1)
  budgetMinMinor            BigInt?                          @map("budget_min_minor")
  budgetMaxMinor            BigInt?                          @map("budget_max_minor")
  ptaPreference             DemandPtaPreference              @default(no_preference) @map("pta_preference")
  urgency                   DemandUrgency                    @default(within_week)
  channel                   DemandChannel                    @default(walk_in)
  status                    DemandStatus                     @default(new)
  outcome                   DemandOutcome                    @default(unknown)
  availabilityState         DemandAvailabilityState          @default(unknown) @map("availability_state")
  availabilityUnknownReason DemandUnknownAvailabilityReason? @map("availability_unknown_reason")
  availableQuantitySnapshot Int?                             @map("available_quantity_snapshot")
  availabilityCheckedAt     DateTime?                        @map("availability_checked_at") @db.Timestamptz(3)
  unitPriceMinorSnapshot    BigInt?                          @map("unit_price_minor_snapshot")
  followUpOn                DateTime?                        @map("follow_up_on") @db.Date
  consentToContact          Boolean                          @default(false) @map("consent_to_contact")
  tradeInInterest           Boolean                          @default(false) @map("trade_in_interest")
  note                      String?                          @db.VarChar(500)
  lostSaleReason            String?                          @map("lost_sale_reason") @db.VarChar(500)
  dedupeGroupId             String?                          @map("dedupe_group_id") @db.Uuid
  convertedTargetType       DemandConversionTargetType?      @map("converted_target_type")
  convertedTargetId         String?                          @map("converted_target_id") @db.Uuid
  convertedAt               DateTime?                        @map("converted_at") @db.Timestamptz(3)
  salespersonUserId         String                           @map("salesperson_user_id") @db.Uuid
  version                   Int                              @default(1)
  createdAt                 DateTime                         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch              @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  customer     Customer?           @relation(fields: [customerId, organizationId], references: [id, organizationId], onDelete: Restrict)
  salesperson  User                @relation("DemandSalesperson", fields: [salespersonUserId, organizationId], references: [id, organizationId], onDelete: Restrict)
  items        DemandRequestItem[]
  followUps    DemandFollowUp[]

  @@unique([organizationId, branchId, requestNumber])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, status, followUpOn])
  @@index([organizationId, branchId, outcome, createdAt(sort: Desc)])
  @@index([organizationId, branchId, urgency, createdAt(sort: Desc)])
  @@index([organizationId, branchId, channel, createdAt(sort: Desc)])
  @@index([organizationId, customerId, createdAt(sort: Desc)])
  @@index([organizationId, branchId, dedupeGroupId])
  @@index([organizationId, branchId, convertedTargetType, convertedTargetId])
  @@map("demand_requests")
}

/// Requested product detail. A match may be attached later, but the customer's
/// original wording is immutable evidence and is never replaced by catalog text.
model DemandRequestItem {
  id                      String            @id @default(uuid()) @db.Uuid
  organizationId          String            @map("organization_id") @db.Uuid
  branchId                String            @map("branch_id") @db.Uuid
  demandRequestId         String            @map("demand_request_id") @db.Uuid
  lineNumber              Int               @map("line_number")
  rawRequestText          String            @map("raw_request_text") @db.VarChar(500)
  matchedProductVariantId String?           @map("matched_product_variant_id") @db.Uuid
  matchedProductModelId   String?           @map("matched_product_model_id") @db.Uuid
  desiredBrand            String?           @map("desired_brand") @db.VarChar(120)
  desiredModel            String?           @map("desired_model") @db.VarChar(120)
  desiredVariant          String?           @map("desired_variant") @db.VarChar(120)
  desiredRam              String?           @map("desired_ram") @db.VarChar(120)
  desiredStorage          String?           @map("desired_storage") @db.VarChar(120)
  desiredColor            String?           @map("desired_color") @db.VarChar(120)
  conditionPreference     ProductCondition? @map("condition_preference")
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch                Branch          @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  demandRequest         DemandRequest   @relation(fields: [demandRequestId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  matchedProductVariant ProductVariant? @relation(fields: [matchedProductVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  matchedProductModel   ProductModel?   @relation(fields: [matchedProductModelId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, demandRequestId, lineNumber])
  @@unique([id, organizationId, branchId])
  @@index([organizationId, matchedProductVariantId, createdAt(sort: Desc)])
  @@index([organizationId, matchedProductModelId, createdAt(sort: Desc)])
  @@index([organizationId, branchId, demandRequestId])
  @@map("demand_request_items")
}

/// Append-only contact/reminder/history evidence. Completion or correction is
/// represented by another row, never by rewriting an earlier interaction.
model DemandFollowUp {
  id              String               @id @default(uuid()) @db.Uuid
  organizationId  String               @map("organization_id") @db.Uuid
  branchId        String               @map("branch_id") @db.Uuid
  demandRequestId String               @map("demand_request_id") @db.Uuid
  occurredAt      DateTime             @map("occurred_at") @db.Timestamptz(3)
  channel         DemandChannel
  result          DemandFollowUpResult
  note            String               @db.VarChar(1000)
  nextFollowUpOn  DateTime?            @map("next_follow_up_on") @db.Date
  actorUserId     String               @map("actor_user_id") @db.Uuid
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch        Branch        @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  demandRequest DemandRequest @relation(fields: [demandRequestId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Restrict)
  actor         User          @relation("DemandFollowUpActor", fields: [actorUserId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([id, organizationId, branchId])
  @@index([organizationId, branchId, demandRequestId, createdAt])
  @@index([organizationId, branchId, nextFollowUpOn])
  @@index([organizationId, actorUserId, createdAt])
  @@map("demand_follow_ups")
}

/// Mirrors shared/src/enums.ts DEMAND_STATUSES exactly.
enum DemandStatus {
  new
  contacted
  sourcing
  available
  customer_notified
  converted_to_sale
  not_interested
  closed
}

/// Mirrors shared/src/enums.ts DEMAND_OUTCOMES exactly.
enum DemandOutcome {
  sold_immediately
  reserved
  quotation_sent
  unavailable
  price_too_high
  customer_postponed
  bought_elsewhere
  incompatible_requirement
  invalid_or_fraudulent
  unknown
}

/// Mirrors shared/src/enums.ts DEMAND_URGENCIES exactly.
enum DemandUrgency {
  immediate
  within_week
  within_month
  flexible
}

/// Mirrors shared/src/enums.ts DEMAND_CHANNELS exactly.
enum DemandChannel {
  walk_in
  phone
  whatsapp
  referral
  other
}

enum DemandPtaPreference {
  pta_only
  non_pta_ok
  no_preference
}

enum DemandAvailabilityState {
  available
  unavailable
  not_in_catalog
  unknown
}

enum DemandUnknownAvailabilityReason {
  not_checked
  permission_denied
  lookup_failed
}

enum DemandConversionTargetType {
  catalog_entry
  quotation
  reservation
  supplier_inquiry
  purchase_recommendation
  sale
}

enum DemandFollowUpResult {
  reached
  no_answer
  message_sent
  customer_replied
  reminder_set
  other
}

// =============================================================================
// Users, roles and permissions
// =============================================================================

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  /// Normalized to lowercase before write; unique per organization.
  email              String    @db.VarChar(255)
  /// Argon2id hash (ASM-012). NEVER logged, never returned by any endpoint.
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  fullName           String    @map("full_name") @db.VarChar(200)
  /// E.164, e.g. +923001234567 (shared/src/phone.ts).
  phone              String?   @db.VarChar(20)
  /// Deactivation revokes access immediately; users are never hard-deleted
  /// because they are referenced by posted records and audit history.
  isActive           Boolean   @default(true) @map("is_active")
  /// Forces a password change on next login (invited or reset users).
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz(3)
  /// Consecutive failed attempts; reset on success. Feeds lockout.
  failedLoginCount   Int       @default(0) @map("failed_login_count")
  lockedUntil        DateTime? @map("locked_until") @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  userRoles         UserRole[]           @relation("UserRoleMember")
  assignedUserRoles UserRole[]           @relation("UserRoleAssigner")
  scopeAccess       UserScopeAccess[]
  sessions          Session[]
  auditEvents       AuditEvent[]
  updatedSettings   ApplicationSetting[] @relation("SettingUpdater")

  inventoryMovements InventoryMovement[] @relation("InventoryMovementActor")

  createdPurchaseOrders   PurchaseOrder[] @relation("PurchaseOrderCreator")
  approvedPurchaseOrders  PurchaseOrder[] @relation("PurchaseOrderApprover")
  orderedPurchaseOrders   PurchaseOrder[] @relation("PurchaseOrderOrderer")
  closedPurchaseOrders    PurchaseOrder[] @relation("PurchaseOrderCloser")
  cancelledPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCanceller")
  receivedGoodsReceipts   GoodsReceipt[]  @relation("GoodsReceiptReceiver")

  cashierCashSessions       CashSession[]    @relation("CashSessionCashier")
  openedCashSessions        CashSession[]    @relation("CashSessionOpener")
  salespersonSales          Sale[]           @relation("SaleSalesperson")
  cashierSales              Sale[]           @relation("SaleCashier")
  approvedSaleDiscounts     Sale[]           @relation("SaleDiscountApprover")
  heldSales                 Sale[]           @relation("SaleHolder")
  cancelledSales            Sale[]           @relation("SaleCanceller")
  receivedPayments          Payment[]        @relation("PaymentReceiver")
  approvedReceivables       Receivable[]     @relation("ReceivableApprover")
  authoredFinancialEntries  FinancialEntry[] @relation("FinancialEntryActor")
  salespersonDemandRequests DemandRequest[]  @relation("DemandSalesperson")
  authoredDemandFollowUps   DemandFollowUp[] @relation("DemandFollowUpActor")
  createdReturns            SaleReturn[]     @relation("ReturnCreator")
  approvedReturns           SaleReturn[]     @relation("ReturnApprover")
  policyOverriddenReturns   SaleReturn[]     @relation("ReturnPolicyOverrider")
  processedRefunds          Refund[]         @relation("RefundProcessor")

  @@unique([organizationId, email])
  @@unique([id, organizationId])
  @@index([organizationId, isActive])
  @@map("users")
}

model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  /// Stable machine code: owner, manager, salesperson, cashier, purchaser,
  /// accountant, technician (shared/src/permissions.ts ROLES).
  code           String   @db.VarChar(50)
  name           String   @db.VarChar(100)
  description    String?  @db.VarChar(500)
  /// System roles are seeded and cannot be deleted; their grants stay editable.
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@map("roles")
}

/// Permission catalogue. Rows mirror shared/src/permissions.ts PERMISSIONS and
/// are reconciled by the seed, so code and database cannot drift apart.
model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  /// resource.action, e.g. "sales.post".
  key         String   @unique @db.VarChar(100)
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?  @db.VarChar(300)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model UserRole {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  roleId         String   @map("role_id") @db.Uuid
  assignedAt     DateTime @default(now()) @map("assigned_at") @db.Timestamptz(3)
  assignedBy     String?  @map("assigned_by_user_id") @db.Uuid

  user     User  @relation("UserRoleMember", fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  role     Role  @relation(fields: [roleId, organizationId], references: [id, organizationId], onDelete: Restrict)
  assigner User? @relation("UserRoleAssigner", fields: [assignedBy, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, userId, roleId])
  @@index([organizationId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at") @db.Timestamptz(3)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// Restricts a user to specific branches/locations (13_ §8, §23.21).
/// A user with NO rows here is scoped to their organization's default branch;
/// resolution lives in the scope guard, never in the client.
model UserScopeAccess {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  /// Null grants the whole branch; non-null narrows the grant to one location.
  locationId     String?  @map("location_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user     User           @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  branch   Branch         @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Cascade)
  location StockLocation? @relation(fields: [locationId, organizationId, branchId], references: [id, organizationId, branchId], onDelete: Cascade)

  @@unique([organizationId, userId, branchId, locationId])
  @@index([organizationId, userId])
  @@map("user_scope_access")
}

// =============================================================================
// Sessions
// =============================================================================

/// Server-side session (ASM-011).
///
/// Server-side rather than a self-contained JWT so that deactivating a user or
/// revoking a session takes effect immediately — 13_ §8 requires activation/
/// deactivation to be meaningful, which a stateless token cannot guarantee until
/// it expires.
model Session {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  /// SHA-256 of the opaque cookie value. The raw token is never stored, so a
  /// database leak does not hand over live sessions.
  tokenHash      String    @unique @map("token_hash") @db.VarChar(64)
  /// Active branch for this session; the launch UI exposes no branch selector.
  branchId       String    @map("branch_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(3)
  /// Truncated/normalized; retained for the login audit trail (13_ §8).
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  userAgent      String?   @map("user_agent") @db.VarChar(400)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  lastSeenAt     DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(3)

  user   User   @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  branch Branch @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Login attempt log, separate from AuditEvent because it is written on failure
/// for users that may not exist, and drives rate limiting/lockout (13_ §8).
model LoginAttempt {
  id            String   @id @default(uuid()) @db.Uuid
  /// Raw submitted identifier, lowercased. Not an FK: failures include unknown users.
  email         String   @db.VarChar(255)
  succeeded     Boolean
  failureReason String?  @map("failure_reason") @db.VarChar(100)
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(400)
  requestId     String?  @map("request_id") @db.VarChar(128)
  attemptedAt   DateTime @default(now()) @map("attempted_at") @db.Timestamptz(3)

  @@index([email, attemptedAt])
  @@index([ipAddress, attemptedAt])
  @@map("login_attempts")
}

// =============================================================================
// Audit
// =============================================================================

/// Append-only audit log (04_DATA_MODEL.md §10, 03_ARCHITECTURE.md §9).
///
/// Never updated or deleted by application code. Payloads hold safe snapshots
/// only — never secrets, tokens, or full sensitive documents (04_DATA_MODEL §10).
model AuditEvent {
  id             String           @id @default(uuid()) @db.Uuid
  occurredAt     DateTime         @default(now()) @map("occurred_at") @db.Timestamptz(3)
  organizationId String           @map("organization_id") @db.Uuid
  branchId       String?          @map("branch_id") @db.Uuid
  /// Null for system/unauthenticated actions (e.g. a failed login).
  actorUserId    String?          @map("actor_user_id") @db.Uuid
  /// Dotted action, e.g. "sale.posted", "inventory.adjusted".
  action         String           @db.VarChar(100)
  entityType     String           @map("entity_type") @db.VarChar(60)
  entityId       String?          @map("entity_id") @db.VarChar(64)
  /// Safe before/after snapshots. Redacted at the writer, not here.
  beforeSnapshot Json?            @map("before_snapshot")
  afterSnapshot  Json?            @map("after_snapshot")
  beforeHash     String?          @map("before_hash") @db.Char(64)
  afterHash      String?          @map("after_hash") @db.Char(64)
  /// Mandatory for overrides and sensitive actions (13_ §23.22).
  reason         String?          @db.VarChar(500)
  requestId      String?          @map("request_id") @db.VarChar(128)
  ipAddress      String?          @map("ip_address") @db.VarChar(45)
  userAgent      String?          @map("user_agent") @db.VarChar(400)
  sensitivity    AuditSensitivity @default(normal)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch?      @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  actor        User?        @relation(fields: [actorUserId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, occurredAt])
  @@index([entityType, entityId])
  @@index([actorUserId, occurredAt])
  @@index([action, occurredAt])
  @@map("audit_events")
}

enum AuditSensitivity {
  normal
  /// Restricted entries (identity documents, exports of personal data) are
  /// visible only to users holding audit.view (04_DATA_MODEL.md §10).
  restricted
}

// =============================================================================
// System
// =============================================================================

/// Runtime configuration the owner can change without a deploy
/// (05_RULES.md §9: "no hidden magic numbers; configuration is named and versioned").
model ApplicationSetting {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  /// Null means organization default; a branch row overrides that default.
  branchId       String?          @map("branch_id") @db.Uuid
  /// Dotted key, e.g. "sales.min_margin_percent".
  key            String           @db.VarChar(120)
  value          Json
  valueType      SettingValueType @default(json) @map("value_type")
  description    String?          @db.VarChar(300)
  /// Optimistic concurrency for concurrent settings edits.
  version        Int              @default(1)
  updatedBy      String?          @map("updated_by") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  updater      User?        @relation("SettingUpdater", fields: [updatedBy, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, branchId, key])
  @@map("application_settings")
}

enum SettingValueType {
  boolean
  integer
  money_minor
  string
  json
}

/// Gapless human-facing document numbers (ASM-018).
///
/// Allocated inside the posting transaction under a row lock, so numbering has
/// no gaps — which is what an auditor expects. At this shop's volume the
/// serialization cost is irrelevant.
model NumberSequence {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String?  @map("branch_id") @db.Uuid
  /// shared/src/constants.ts SEQUENCE_KEYS, e.g. "sale_invoice".
  key            String   @db.VarChar(60)
  prefix         String   @default("") @db.VarChar(20)
  /// Next value to issue, allocated and incremented under a row lock.
  nextValue      Int      @default(1) @map("next_value")
  padding        Int      @default(6)
  /// Optional period segment (e.g. "2026") that resets numbering per year.
  periodKey      String?  @map("period_key") @db.VarChar(10)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([organizationId, branchId, key, periodKey])
  @@map("number_sequences")
}
